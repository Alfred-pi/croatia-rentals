---
import Layout from '../layouts/Layout.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<Layout title="Contact — ADRIATIC">
  <section class="contact">
    <div class="contact__info">
      <span>Contact</span>
      <h1>Let's talk</h1>
      <p>Tell us about your ideal Croatian retreat and we'll help make it happen.</p>
      
      <div class="contact__details">
        <div class="detail">
          <span>Email</span>
          <a href="mailto:hello@adriatic.hr">hello@adriatic.hr</a>
        </div>
        <div class="detail">
          <span>Phone</span>
          <a href="tel:+385912345678">+385 91 234 5678</a>
        </div>
        <div class="detail">
          <span>Based in</span>
          <p>Dubrovnik, Croatia</p>
        </div>
      </div>
    </div>
    
    <div class="contact__form">
      <form action="https://formsubmit.co/hello@adriatic.hr" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" name="first_name" required />
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" name="last_name" required />
          </div>
        </div>
        
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required />
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label>Check-in</label>
            <input type="date" name="checkin" />
          </div>
          <div class="form-group">
            <label>Check-out</label>
            <input type="date" name="checkout" />
          </div>
        </div>
        
        <div class="form-group">
          <label>Guests</label>
          <select name="guests">
            <option>2 guests</option>
            <option>4 guests</option>
            <option>6 guests</option>
            <option>8+ guests</option>
          </select>
        </div>
        
        <div class="form-group">
          <label>Message</label>
          <textarea name="message" rows="4" placeholder="Tell us about your trip..."></textarea>
        </div>
        
        <button type="submit" class="btn btn--fill">Send Inquiry</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    padding-top: 72px;
  }
  
  .contact__info {
    padding: 100px 10%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .contact__info span {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 24px;
  }
  
  .contact__info h1 {
    font-size: clamp(40px, 5vw, 56px);
    margin-bottom: 20px;
  }
  
  .contact__info > p {
    font-size: 16px;
    color: var(--gray);
    max-width: 360px;
    line-height: 1.8;
  }
  
  .contact__details {
    margin-top: 60px;
  }
  
  .detail {
    margin-bottom: 28px;
  }
  
  .detail span {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    display: block;
    margin-bottom: 8px;
  }
  
  .detail a,
  .detail p {
    font-size: 18px;
    color: var(--black);
  }
  
  .detail a:hover {
    color: var(--gold);
  }
  
  .contact__form {
    background: var(--light);
    padding: 100px 10%;
    display: flex;
    align-items: center;
  }
  
  form {
    width: 100%;
    max-width: 480px;
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  
  .form-group {
    margin-bottom: 24px;
  }
  
  label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 10px;
  }
  
  input,
  select,
  textarea {
    width: 100%;
    padding: 14px 0;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    border: none;
    border-bottom: 1px solid var(--gray);
    background: transparent;
    color: var(--black);
    transition: border-color 0.3s;
  }
  
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--gold);
  }
  
  textarea {
    resize: vertical;
    min-height: 100px;
  }
  
  button {
    margin-top: 20px;
    width: 100%;
  }
  
  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
    }
    
    .contact__info {
      padding: 120px 5% 60px;
    }
    
    .contact__form {
      padding: 60px 5%;
    }
    
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>
