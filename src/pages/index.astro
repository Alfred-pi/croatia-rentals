---
// Azura Villas - Croatian Luxury Retreats
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Azura Villas | Croatian Luxury Retreats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    :root {
      --azure: #0EA5E9;
      --azure-dark: #0284C7;
      --azure-light: #38BDF8;
      --midnight: #0F172A;
      --slate: #334155;
      --stone: #78716C;
      --sand: #F5F5F4;
      --white: #FFFFFF;
      --cream: #FAFAF9;
    }
    
    html { scroll-behavior: smooth; }
    
    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--midnight);
      background: var(--white);
      line-height: 1.6;
    }
    
    h1, h2, h3 { font-family: 'DM Serif Display', serif; font-weight: 400; }
    
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    
    .container { max-width: 1320px; margin: 0 auto; padding: 0 24px; }
    
    /* NAV */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 20px 40px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    
    .nav__logo {
      font-family: 'DM Serif Display', serif;
      font-size: 28px;
      color: var(--azure);
    }
    
    .nav__links { display: flex; gap: 36px; align-items: center; }
    .nav__links a { font-size: 15px; font-weight: 500; color: var(--slate); transition: color 0.2s; }
    .nav__links a:hover { color: var(--azure); }
    
    .nav__cta {
      padding: 12px 28px;
      background: var(--azure);
      color: white !important;
      border-radius: 100px;
      font-weight: 600;
    }
    .nav__cta:hover { background: var(--azure-dark); }
    
    /* HERO - Split layout */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    
    .hero__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 140px 80px 80px;
      background: var(--cream);
    }
    
    .hero__badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: rgba(14, 165, 233, 0.1);
      color: var(--azure);
      font-size: 13px;
      font-weight: 600;
      border-radius: 100px;
      width: fit-content;
      margin-bottom: 32px;
    }
    
    .hero__badge::before {
      content: '';
      width: 8px; height: 8px;
      background: var(--azure);
      border-radius: 50%;
    }
    
    .hero__title {
      font-size: clamp(48px, 5vw, 64px);
      line-height: 1.1;
      margin-bottom: 24px;
      color: var(--midnight);
    }
    
    .hero__title span { color: var(--azure); }
    
    .hero__desc {
      font-size: 18px;
      color: var(--slate);
      max-width: 480px;
      margin-bottom: 40px;
      line-height: 1.7;
    }
    
    .hero__actions { display: flex; gap: 16px; }
    
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 16px 32px;
      font-size: 15px;
      font-weight: 600;
      border-radius: 100px;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .btn--primary {
      background: var(--azure);
      color: white;
    }
    .btn--primary:hover {
      background: var(--azure-dark);
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(14, 165, 233, 0.25);
    }
    
    .btn--outline {
      background: transparent;
      color: var(--midnight);
      border: 2px solid var(--midnight);
    }
    .btn--outline:hover {
      background: var(--midnight);
      color: white;
    }
    
    .hero__stats {
      display: flex;
      gap: 48px;
      margin-top: 60px;
      padding-top: 40px;
      border-top: 1px solid rgba(0,0,0,0.1);
    }
    
    .hero__stat-number {
      font-family: 'DM Serif Display', serif;
      font-size: 42px;
      color: var(--azure);
    }
    
    .hero__stat-label {
      font-size: 14px;
      color: var(--stone);
      margin-top: 4px;
    }
    
    .hero__image {
      position: relative;
      overflow: hidden;
    }
    
    .hero__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .hero__image-overlay {
      position: absolute;
      bottom: 40px;
      left: 40px;
      right: 40px;
      padding: 24px;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      display: flex;
      align-items: center;
      gap: 20px;
    }
    
    .hero__image-overlay img {
      width: 80px;
      height: 80px;
      border-radius: 12px;
      object-fit: cover;
    }
    
    .hero__overlay-text h4 {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
    }
    
    .hero__overlay-text p {
      font-size: 14px;
      color: var(--stone);
    }
    
    .hero__overlay-price {
      margin-left: auto;
      text-align: right;
    }
    
    .hero__overlay-price span {
      display: block;
      font-size: 13px;
      color: var(--stone);
    }
    
    .hero__overlay-price strong {
      font-size: 24px;
      color: var(--azure);
    }
    
    /* PROPERTIES */
    .properties {
      padding: 120px 0;
      background: var(--white);
    }
    
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 60px;
    }
    
    .section-header h2 {
      font-size: clamp(36px, 4vw, 48px);
      color: var(--midnight);
    }
    
    .section-header p {
      font-size: 17px;
      color: var(--slate);
      max-width: 400px;
      margin-top: 12px;
    }
    
    .section-header a {
      font-size: 15px;
      font-weight: 600;
      color: var(--azure);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .section-header a:hover { text-decoration: underline; }
    
    .properties__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    
    .property {
      background: var(--cream);
      border-radius: 24px;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .property:hover {
      transform: translateY(-8px);
      box-shadow: 0 24px 48px rgba(0,0,0,0.08);
    }
    
    .property__image {
      position: relative;
      aspect-ratio: 4/3;
      overflow: hidden;
    }
    
    .property__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }
    
    .property:hover .property__image img {
      transform: scale(1.05);
    }
    
    .property__tag {
      position: absolute;
      top: 16px;
      left: 16px;
      padding: 8px 16px;
      background: var(--azure);
      color: white;
      font-size: 12px;
      font-weight: 600;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .property__content { padding: 28px; }
    
    .property__location {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--azure);
      font-weight: 500;
      margin-bottom: 8px;
    }
    
    .property__title {
      font-size: 22px;
      margin-bottom: 12px;
      color: var(--midnight);
    }
    
    .property__features {
      display: flex;
      gap: 16px;
      font-size: 14px;
      color: var(--stone);
      margin-bottom: 20px;
    }
    
    .property__features span {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .property__footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 20px;
      border-top: 1px solid rgba(0,0,0,0.08);
    }
    
    .property__price {
      font-size: 24px;
      font-weight: 700;
      color: var(--midnight);
    }
    
    .property__price span {
      font-size: 14px;
      font-weight: 400;
      color: var(--stone);
    }
    
    .property__link {
      width: 48px;
      height: 48px;
      background: var(--azure);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 20px;
      transition: background 0.2s;
    }
    
    .property__link:hover { background: var(--azure-dark); }
    
    /* FEATURES */
    .features {
      padding: 120px 0;
      background: var(--midnight);
      color: white;
    }
    
    .features .section-header h2 { color: white; }
    .features .section-header p { color: rgba(255,255,255,0.6); }
    
    .features__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
    
    .feature {
      padding: 40px 32px;
      background: rgba(255,255,255,0.05);
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.1);
      transition: background 0.3s;
    }
    
    .feature:hover { background: rgba(255,255,255,0.1); }
    
    .feature__icon {
      width: 64px;
      height: 64px;
      background: var(--azure);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      margin-bottom: 24px;
    }
    
    .feature h4 {
      font-family: 'DM Sans', sans-serif;
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 12px;
    }
    
    .feature p {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
    }
    
    /* TOUR */
    .tour {
      padding: 120px 0;
      background: var(--cream);
    }
    
    .tour__wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    
    .tour__content h2 {
      font-size: clamp(36px, 4vw, 48px);
      margin-bottom: 24px;
      color: var(--midnight);
    }
    
    .tour__content p {
      font-size: 17px;
      color: var(--slate);
      line-height: 1.7;
      margin-bottom: 32px;
    }
    
    .tour__list {
      list-style: none;
      margin-bottom: 40px;
    }
    
    .tour__list li {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      font-size: 16px;
      color: var(--slate);
    }
    
    .tour__list li::before {
      content: '✓';
      width: 24px;
      height: 24px;
      background: rgba(14, 165, 233, 0.1);
      color: var(--azure);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: bold;
    }
    
    .tour__video {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      aspect-ratio: 16/10;
    }
    
    .tour__video img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .tour__play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 80px;
      height: 80px;
      background: var(--azure);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 24px;
      cursor: pointer;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .tour__play:hover {
      transform: translate(-50%, -50%) scale(1.1);
      box-shadow: 0 0 0 20px rgba(14, 165, 233, 0.2);
    }
    
    /* CONTACT */
    .contact {
      padding: 120px 0;
      background: var(--white);
    }
    
    .contact__wrapper {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
    }
    
    .contact__info h2 {
      font-size: clamp(36px, 4vw, 48px);
      margin-bottom: 24px;
      color: var(--midnight);
    }
    
    .contact__info > p {
      font-size: 17px;
      color: var(--slate);
      line-height: 1.7;
      margin-bottom: 40px;
    }
    
    .contact__details { display: flex; flex-direction: column; gap: 24px; }
    
    .contact__item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    
    .contact__icon {
      width: 48px;
      height: 48px;
      background: rgba(14, 165, 233, 0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      color: var(--azure);
    }
    
    .contact__item h5 {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--midnight);
    }
    
    .contact__item p, .contact__item a {
      font-size: 15px;
      color: var(--slate);
    }
    
    .contact__item a:hover { color: var(--azure); }
    
    .contact__form {
      background: var(--cream);
      padding: 48px;
      border-radius: 24px;
    }
    
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    
    .form-group { margin-bottom: 24px; }
    
    .form-group label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      color: var(--midnight);
      margin-bottom: 8px;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 16px 20px;
      font-size: 15px;
      font-family: inherit;
      border: 2px solid transparent;
      background: var(--white);
      border-radius: 12px;
      color: var(--midnight);
      transition: border-color 0.2s;
    }
    
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--azure);
    }
    
    .form-group textarea { resize: vertical; min-height: 120px; }
    
    .contact__form .btn { width: 100%; justify-content: center; }
    
    /* FOOTER */
    .footer {
      background: var(--midnight);
      color: white;
      padding: 80px 0 40px;
    }
    
    .footer__grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px;
      padding-bottom: 60px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .footer__brand .nav__logo { margin-bottom: 20px; }
    
    .footer__brand p {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      max-width: 300px;
    }
    
    .footer__col h5 {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    .footer__col ul { list-style: none; }
    
    .footer__col li { margin-bottom: 12px; }
    
    .footer__col a {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      transition: color 0.2s;
    }
    
    .footer__col a:hover { color: var(--azure); }
    
    .footer__bottom {
      padding-top: 40px;
      display: flex;
      justify-content: space-between;
      font-size: 14px;
      color: rgba(255,255,255,0.4);
    }
    
    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .hero { grid-template-columns: 1fr; }
      .hero__content { padding: 120px 40px 60px; }
      .hero__image { min-height: 500px; }
      .properties__grid { grid-template-columns: repeat(2, 1fr); }
      .features__grid { grid-template-columns: repeat(2, 1fr); }
      .tour__wrapper { grid-template-columns: 1fr; }
      .contact__wrapper { grid-template-columns: 1fr; }
      .footer__grid { grid-template-columns: 1fr 1fr; }
    }
    
    @media (max-width: 768px) {
      .nav__links { display: none; }
      .nav { padding: 16px 24px; }
      .hero__content { padding: 100px 24px 40px; }
      .hero__stats { flex-wrap: wrap; gap: 24px; }
      .hero__image-overlay { flex-wrap: wrap; }
      .properties__grid { grid-template-columns: 1fr; }
      .features__grid { grid-template-columns: 1fr; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 16px; }
      .form-row { grid-template-columns: 1fr; }
      .contact__form { padding: 32px 24px; }
      .footer__grid { grid-template-columns: 1fr; gap: 40px; }
      .footer__bottom { flex-direction: column; gap: 12px; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav__logo">Azura</a>
    <div class="nav__links">
      <a href="#properties">Villas</a>
      <a href="#features">Services</a>
      <a href="#tour">Virtual Tour</a>
      <a href="#contact" class="nav__cta">Book Now</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__content">
      <div class="hero__badge">Premium Croatian Villas</div>
      <h1 class="hero__title">Your Dream <span>Adriatic</span> Escape Awaits</h1>
      <p class="hero__desc">
        Discover handpicked luxury villas along Croatia's stunning coastline. 
        Private pools, breathtaking views, and world-class service.
      </p>
      <div class="hero__actions">
        <a href="#properties" class="btn btn--primary">Explore Villas</a>
        <a href="#tour" class="btn btn--outline">Take a Tour</a>
      </div>
      <div class="hero__stats">
        <div>
          <div class="hero__stat-number">50+</div>
          <div class="hero__stat-label">Exclusive Villas</div>
        </div>
        <div>
          <div class="hero__stat-number">4.9</div>
          <div class="hero__stat-label">Guest Rating</div>
        </div>
        <div>
          <div class="hero__stat-number">24/7</div>
          <div class="hero__stat-label">Concierge</div>
        </div>
      </div>
    </div>
    <div class="hero__image">
      <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1200&q=90&auto=format" alt="Luxury villa with infinity pool" />
      <div class="hero__image-overlay">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=200&q=85&auto=format" alt="Villa preview" />
        <div class="hero__overlay-text">
          <h4>Villa Azure, Dubrovnik</h4>
          <p>4 beds · Private pool · Sea view</p>
        </div>
        <div class="hero__overlay-price">
          <span>From</span>
          <strong>€580/night</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- PROPERTIES -->
  <section class="properties" id="properties">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Featured Villas</h2>
          <p>Hand-selected properties for unforgettable Croatian holidays</p>
        </div>
        <a href="#">View all properties →</a>
      </div>
      
      <div class="properties__grid">
        <article class="property">
          <div class="property__image">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85&auto=format" alt="Villa Sunset" loading="lazy" />
            <span class="property__tag">Popular</span>
          </div>
          <div class="property__content">
            <div class="property__location">📍 Dubrovnik</div>
            <h3 class="property__title">Villa Sunset Retreat</h3>
            <div class="property__features">
              <span>🛏 4 Beds</span>
              <span>🛁 3 Baths</span>
              <span>📐 280m²</span>
            </div>
            <div class="property__footer">
              <div class="property__price">€580 <span>/night</span></div>
              <a href="#" class="property__link">→</a>
            </div>
          </div>
        </article>
        
        <article class="property">
          <div class="property__image">
            <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format" alt="Coastal Haven" loading="lazy" />
            <span class="property__tag">Sea View</span>
          </div>
          <div class="property__content">
            <div class="property__location">📍 Split</div>
            <h3 class="property__title">Coastal Haven Loft</h3>
            <div class="property__features">
              <span>🛏 3 Beds</span>
              <span>🛁 2 Baths</span>
              <span>📐 165m²</span>
            </div>
            <div class="property__footer">
              <div class="property__price">€420 <span>/night</span></div>
              <a href="#" class="property__link">→</a>
            </div>
          </div>
        </article>
        
        <article class="property">
          <div class="property__image">
            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85&auto=format" alt="Island Estate" loading="lazy" />
            <span class="property__tag">Luxury</span>
          </div>
          <div class="property__content">
            <div class="property__location">📍 Hvar</div>
            <h3 class="property__title">Island Estate Villa</h3>
            <div class="property__features">
              <span>🛏 5 Beds</span>
              <span>🛁 4 Baths</span>
              <span>📐 420m²</span>
            </div>
            <div class="property__footer">
              <div class="property__price">€890 <span>/night</span></div>
              <a href="#" class="property__link">→</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Premium Services</h2>
          <p>Everything you need for the perfect Croatian getaway</p>
