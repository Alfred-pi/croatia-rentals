---
// Croatia Luxury Rentals - Ultra Premium Edition
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Adriatic Prestige | Exclusive Croatian Villa Rentals</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --champagne: #D4AF37;
        --champagne-light: #E8D5A3;
        --champagne-dark: #B8962F;
        --noir: #0A0A0A;
        --noir-light: #1A1A1A;
        --ivory: #FAF8F5;
        --ivory-warm: #F5F0E8;
        --slate: #2C2C2C;
        --muted: #8A8A8A;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Outfit', sans-serif;
        background: var(--noir);
        color: var(--ivory);
        line-height: 1.6;
        font-weight: 300;
        overflow-x: hidden;
      }

      h1, h2, h3, h4 {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 400;
        letter-spacing: 0.02em;
      }

      /* Cursor glow effect */
      .cursor-glow {
        position: fixed;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(212, 175, 55, 0.03) 0%, transparent 70%);
        pointer-events: none;
        transform: translate(-50%, -50%);
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      /* Navigation */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 2rem 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      nav.scrolled {
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(20px);
        padding: 1.2rem 5%;
        border-bottom: 1px solid rgba(212, 175, 55, 0.1);
      }

      .logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.8rem;
        font-weight: 400;
        color: var(--ivory);
        text-decoration: none;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .logo span {
        color: var(--champagne);
        font-style: italic;
        font-weight: 300;
      }

      .nav-links {
        display: flex;
        gap: 3rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--ivory);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 400;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        position: relative;
        padding-bottom: 4px;
      }

      .nav-links a::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--champagne);
        transition: width 0.3s ease;
      }

      .nav-links a:hover::after {
        width: 100%;
      }

      /* Hero Section - Full immersive */
      .hero {
        height: 100vh;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=2000&q=90') center/cover;
        transform: scale(1.05);
        animation: heroZoom 20s ease-out forwards;
      }

      @keyframes heroZoom {
        to { transform: scale(1); }
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          rgba(10, 10, 10, 0.85) 0%,
          rgba(10, 10, 10, 0.4) 50%,
          rgba(10, 10, 10, 0.2) 100%
        );
      }

      .hero-content {
        position: relative;
        z-index: 2;
        padding: 8rem 5%;
        max-width: 700px;
      }

      .hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--champagne);
        margin-bottom: 2rem;
      }

      .hero-tag::before {
        content: '';
        width: 40px;
        height: 1px;
        background: var(--champagne);
      }

      .hero h1 {
        font-size: clamp(3rem, 7vw, 5.5rem);
        font-weight: 300;
        line-height: 1.1;
        margin-bottom: 2rem;
      }

      .hero h1 em {
        font-style: italic;
        color: var(--champagne);
      }

      .hero-description {
        font-size: 1.1rem;
        line-height: 1.8;
        color: rgba(250, 248, 245, 0.7);
        margin-bottom: 3rem;
        max-width: 500px;
      }

      .btn-group {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.2rem 2.5rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border: none;
      }

      .btn-primary {
        background: var(--champagne);
        color: var(--noir);
      }

      .btn-primary:hover {
        background: var(--champagne-light);
        transform: translateY(-3px);
        box-shadow: 0 20px 40px rgba(212, 175, 55, 0.3);
      }

      .btn-outline {
        border: 1px solid rgba(250, 248, 245, 0.3);
        color: var(--ivory);
        background: transparent;
      }

      .btn-outline:hover {
        border-color: var(--champagne);
        color: var(--champagne);
        background: rgba(212, 175, 55, 0.05);
      }

      /* Scroll indicator */
      .scroll-indicator {
        position: absolute;
        bottom: 3rem;
        right: 5%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        color: var(--muted);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .scroll-line {
        width: 1px;
        height: 60px;
        background: linear-gradient(to bottom, var(--champagne), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
      }

      @keyframes scrollPulse {
        0%, 100% { opacity: 1; transform: scaleY(1); }
        50% { opacity: 0.5; transform: scaleY(0.8); }
      }

      /* Intro Section */
      .intro {
        padding: 10rem 5%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: center;
        max-width: 1600px;
        margin: 0 auto;
      }

      .intro-content h2 {
        font-size: 3rem;
        line-height: 1.2;
        margin-bottom: 2rem;
      }

      .intro-content p {
        font-size: 1.05rem;
        line-height: 2;
        color: var(--muted);
        margin-bottom: 2rem;
      }

      .intro-stats {
        display: flex;
        gap: 4rem;
        margin-top: 3rem;
        padding-top: 3rem;
        border-top: 1px solid rgba(255,255,255,0.1);
      }

      .stat {
        text-align: left;
      }

      .stat-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        color: var(--champagne);
        font-weight: 300;
      }

      .stat-label {
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 0.5rem;
      }

      .intro-images {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      .intro-img {
        aspect-ratio: 3/4;
        background-size: cover;
        background-position: center;
        position: relative;
        overflow: hidden;
      }

      .intro-img:first-child {
        margin-top: 3rem;
      }

      .intro-img::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10,10,10,0.3), transparent);
      }

      /* Properties Section */
      .properties {
        padding: 8rem 5%;
        background: var(--noir-light);
      }

      .section-header {
        text-align: center;
        margin-bottom: 5rem;
      }

      .section-tag {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--champagne);
        margin-bottom: 1.5rem;
      }

      .section-tag::before,
      .section-tag::after {
        content: '';
        width: 30px;
        height: 1px;
        background: var(--champagne);
      }

      .section-header h2 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 300;
      }

      .properties-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        max-width: 1600px;
        margin: 0 auto;
      }

      .property-card {
        position: relative;
        aspect-ratio: 3/4;
        overflow: hidden;
        cursor: pointer;
        group: true;
      }

      .property-image {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .property-card:hover .property-image {
        transform: scale(1.08);
      }

      .property-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(10, 10, 10, 0.9) 0%,
          rgba(10, 10, 10, 0.3) 40%,
          transparent 100%
        );
        transition: all 0.4s ease;
      }

      .property-card:hover .property-overlay {
        background: linear-gradient(
          to top,
          rgba(10, 10, 10, 0.95) 0%,
          rgba(10, 10, 10, 0.5) 50%,
          rgba(10, 10, 10, 0.2) 100%
        );
      }

      .property-badge {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        background: var(--champagne);
        color: var(--noir);
        padding: 0.5rem 1rem;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .property-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem;
        transform: translateY(20px);
        opacity: 0.9;
        transition: all 0.4s ease;
      }

      .property-card:hover .property-content {
        transform: translateY(0);
        opacity: 1;
      }

      .property-location {
        font-size: 0.7rem;
        color: var(--champagne);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
      }

      .property-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.8rem;
        font-weight: 400;
        margin-bottom: 1rem;
        line-height: 1.3;
      }

      .property-features {
        display: flex;
        gap: 1.5rem;
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }

      .property-price {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
      }

      .price span {
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .view-btn {
        font-size: 0.7rem;
        color: var(--champagne);
        text-decoration: none;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: gap 0.3s ease;
      }

      .view-btn:hover {
        gap: 0.8rem;
      }

      /* 3D Virtual Tour Section */
      .tour-section {
        padding: 10rem 5%;
        position: relative;
        overflow: hidden;
      }

      .tour-bg {
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=2000&q=85') center/cover;
        opacity: 0.15;
      }

      .tour-container {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 6rem;
        align-items: center;
        position: relative;
        z-index: 2;
      }

      .tour-content h2 {
        font-size: 3.5rem;
        line-height: 1.15;
        margin-bottom: 2rem;
      }

      .tour-content h2 em {
        font-style: italic;
        color: var(--champagne);
      }

      .tour-content p {
        font-size: 1.05rem;
        line-height: 2;
        color: var(--muted);
        margin-bottom: 2.5rem;
      }

      .tour-features {
        list-style: none;
        margin-bottom: 3rem;
      }

      .tour-features li {
        padding: 1rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.95rem;
        color: rgba(250, 248, 245, 0.8);
      }

      .tour-features li::before {
        content: "✦";
        color: var(--champagne);
        font-size: 0.6rem;
      }

      .tour-preview {
        position: relative;
        aspect-ratio: 16/10;
        border: 1px solid rgba(212, 175, 55, 0.2);
        overflow: hidden;
      }

      .tour-preview-inner {
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1200&q=85') center/cover;
        transition: transform 0.6s ease;
      }

      .tour-preview:hover .tour-preview-inner {
        transform: scale(1.05);
      }

      .tour-preview-overlay {
        position: absolute;
        inset: 0;
        background: rgba(10, 10, 10, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .play-button {
        width: 100px;
        height: 100px;
        background: var(--champagne);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
      }

      .play-button::before {
        content: '';
        position: absolute;
        inset: -15px;
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 50%;
        animation: playPulse 2s ease-in-out infinite;
      }

      @keyframes playPulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.5; }
      }

      .play-button::after {
        content: "";
        border-left: 18px solid var(--noir);
        border-top: 11px solid transparent;
        border-bottom: 11px solid transparent;
        margin-left: 5px;
      }

      .play-button:hover {
        transform: scale(1.1);
        box-shadow: 0 0 60px rgba(212, 175, 55, 0.4);
      }

      .tour-label {
        position: absolute;
        bottom: 2rem;
        left: 2rem;
        background: rgba(10, 10, 10, 0.8);
        backdrop-filter: blur(10px);
        padding: 1rem 1.5rem;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        border: 1px solid rgba(212, 175, 55, 0.2);
      }

      /* Experience Section */
      .experience {
        padding: 10rem 5%;
        background: var(--ivory);
        color: var(--noir);
      }

      .experience .section-tag {
        color: var(--champagne-dark);
      }

      .experience .section-tag::before,
      .experience .section-tag::after {
        background: var(--champagne-dark);
      }

      .experience .section-header h2 {
        color: var(--noir);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 3rem;
        max-width: 1400px;
        margin: 0 auto;
      }

      .feature-card {
        text-align: center;
        padding: 3rem 2rem;
        background: var(--ivory-warm);
        transition: all 0.4s ease;
      }

      .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
      }

      .feature-icon {
        width: 70px;
        height: 70px;
        margin: 0 auto 2rem;
        background: var(--noir);
        color: var(--champagne);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
      }

      .feature-card h3 {
        font-size: 1.3rem;
        color: var(--noir);
        margin-bottom: 1rem;
        font-weight: 400;
      }

      .feature-card p {
        font-size: 0.9rem;
        color: var(--slate);
        line-height: 1.7;
      }

      /* Contact Section */
      .contact {
        padding: 10rem 5%;
        background: var(--noir);
      }

      .contact-container {
        max-width: 900px;
        margin: 0 auto;
      }

      .contact .section-header {
        margin-bottom: 4rem;
      }

      .contact .section-header p {
        color: var(--muted);
        font-size: 1.1rem;
        margin-top: 1rem;
      }

      .contact-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }

      .form-group {
        display: flex;
        flex-direction: column;
      }

      .form-group.full-width {
        grid-column: span 2;
      }

      .form-group label {
        font-size: 0.7rem;
        font-weight: 400;
        margin-bottom: 0.75rem;
        color: var(--champagne);
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .form-group input,
      .form-group textarea,
      .form-group select {
        padding: 1.25rem;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: var(--ivory);
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 300;
        transition: all 0.3s ease;
      }

      .form-group input::placeholder,
      .form-group textarea::placeholder {
        color: var(--muted);
      }

      .form-group input:focus,
      .form-group textarea:focus,
      .form-group select:focus {
        outline: none;
        border-color: var(--champagne);
        background: rgba(212, 175, 55, 0.03);
      }

      .form-group select {
        cursor: pointer;
      }

      .form-group select option {
        background: var(--noir);
        color: var(--ivory);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 150px;
      }

      .contact-form .btn {
        grid-column: span 2;
        justify-self: center;
        margin-top: 2rem;
        min-width: 250px;
        justify-content: center;
      }

      /* Footer */
      footer {
        background: var(--noir-light);
        padding: 5rem 5%;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
      }

      .footer-content {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .footer-logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        color: var(--ivory);
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .footer-logo span {
        color: var(--champagne);
        font-style: italic;
      }

      .footer-links {
        display: flex;
        gap: 3rem;
        list-style: none;
      }

      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        transition: color 0.3s ease;
      }

      .footer-links a:hover {
        color: var(--champagne);
      }

      .footer-bottom {
        max-width: 1400px;
        margin: 3rem auto 0;
        padding-top: 3rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        text-align: center;
        font-size: 0.8rem;
        color: var(--muted);
      }

      /* Responsive */
      @media (max-width: 1200px) {
        .properties-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .features-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 1024px) {
        .intro {
          grid-template-columns: 1fr;
          gap: 4rem;
        }

        .intro-images {
          order: -1;
        }

        .tour-container {
          grid-template-columns: 1fr;
          gap: 4rem;
        }
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .hero h1 {
          font-size: 2.5rem;
        }

        .hero-content {
          padding: 4rem 5%;
        }

        .properties-grid {
          grid-template-columns: 1fr;
        }

        .features-grid {
          grid-template-columns: 1fr;
        }

        .contact-form {
          grid-template-columns: 1fr;
        }

        .form-group.full-width {
          grid-column: span 1;
        }

        .contact-form .btn {
          grid-column: span 1;
          width: 100%;
        }

        .footer-content {
          flex-direction: column;
          gap: 2rem;
          text-align: center;
        }

        .footer-links {
          flex-wrap: wrap;
          justify-content: center;
        }

        .intro-stats {
          flex-wrap: wrap;
          gap: 2rem;
        }
      }

      /* Smooth reveal animations */
      .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <!-- Navigation -->
    <nav id="navbar">
      <a href="/" class="logo">Adriatic <span>Prestige</span></a>
      <ul class="nav-links">
        <li><a href="#properties">Residences</a></li>
        <li><a href="#tour">Virtual Tour</a></li>
        <li><a href="#experience">Experience</a></li>
