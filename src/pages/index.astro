---
import Layout from '../layouts/Layout.astro';

const villas = [
  { name: 'Villa Pietra', location: 'Dubrovnik', price: 890, image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85', slug: 'villa-pietra', airbnb: 'https://airbnb.com/rooms/123456' },
  { name: 'Casa Blu', location: 'Hvar', price: 1200, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85', slug: 'casa-blu', airbnb: 'https://airbnb.com/rooms/234567' },
  { name: 'Villa Oliva', location: 'Split', price: 750, image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85', slug: 'villa-oliva', airbnb: 'https://airbnb.com/rooms/345678' },
];

const destinations = [
  { name: 'Dubrovnik', tagline: 'Pearl of the Adriatic', image: 'https://images.unsplash.com/photo-1555990538-1e15d5b97d8d?w=600&q=85' },
  { name: 'Hvar', tagline: 'Island of endless sun', image: 'https://images.unsplash.com/photo-1534008897995-27a23e859048?w=600&q=85' },
  { name: 'Split', tagline: 'Ancient Roman splendor', image: 'https://images.unsplash.com/photo-1592499453756-ee2368f632ee?w=600&q=85' },
];

const testimonials = [
  { text: "An absolutely unforgettable experience. The villa exceeded all expectations and the attention to detail was remarkable.", author: "James & Sarah Mitchell", from: "London, UK", rating: 5 },
  { text: "We've traveled the world, but Croatia with Adriatic was truly special. Already planning our return.", author: "The Martinez Family", from: "Miami, USA", rating: 5 },
  { text: "From booking to checkout, everything was seamless. The concierge service is world-class.", author: "Sophie Laurent", from: "Paris, France", rating: 5 },
];

const press = [
  { name: 'Condé Nast Traveler', quote: 'The finest collection of Croatian villas' },
  { name: 'Vogue Living', quote: 'Understated luxury at its best' },
  { name: 'Monocle', quote: 'A new standard in Mediterranean rentals' },
];
---

<Layout title="ADRIATIC — Luxury Croatian Villas">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <div class="hero__tag-line">
        <span class="tag">Est. 2018</span>
        <span class="hero__divider"></span>
        <span class="tag">Croatian Riviera</span>
      </div>
      <h1>Where the<br/>Adriatic meets<br/><em>luxury</em></h1>
      <div class="line"></div>
      <p>A curated collection of exceptional private villas along Croatia's most coveted coastline. Also available on Airbnb.</p>
      <div class="hero__buttons">
        <a href="/croatia-rentals/villas/" class="btn">Explore Collection</a>
        <a href="https://airbnb.com" target="_blank" class="btn btn--outline">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.42 0 5.82 1.96 4.63 4.38c-.6 1.21-.93 2.6-.93 4.1 0 3.04 1.67 5.8 3.17 7.94.49.7.98 1.35 1.43 1.96.5.68.95 1.3 1.31 1.87.37.58.64 1.1.79 1.52.16.46.3.98.41 1.52.12.54.21 1.09.27 1.63.06.54.09 1.07.09 1.58 0 .4-.02.78-.07 1.13-.05.36-.12.69-.22.98-.1.3-.22.56-.37.78s-.32.4-.52.52c-.2.13-.43.2-.67.2-.24 0-.47-.07-.67-.2-.2-.12-.37-.3-.52-.52s-.27-.48-.37-.78c-.1-.29-.17-.62-.22-.98-.05-.35-.07-.73-.07-1.13 0-.51.03-1.04.09-1.58.06-.54.15-1.09.27-1.63.11-.54.25-1.06.41-1.52.15-.42.42-.94.79-1.52.36-.57.81-1.19 1.31-1.87.45-.61.94-1.26 1.43-1.96 1.5-2.14 3.17-4.9 3.17-7.94 0-1.5-.33-2.89-.93-4.1C18.18 1.96 15.58 0 12 0z"/></svg>
          View on Airbnb
        </a>
      </div>
    </div>
    <div class="hero__image">
      <div class="hero__image-wrapper">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1400&q=90" alt="Luxury villa" class="parallax-img" />
      </div>
      <div class="hero__badge">
        <span class="hero__badge-rating">4.98</span>
        <span class="hero__badge-text">Superhost on Airbnb</span>
      </div>
      <div class="hero__scroll">
        <span>Scroll</span>
        <div class="hero__scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- Press -->
  <section class="press">
    {press.map(p => (
      <div class="press__item reveal">
        <span class="press__name">{p.name}</span>
        <span class="press__quote">"{p.quote}"</span>
      </div>
    ))}
  </section>

  <!-- Intro -->
  <section class="intro reveal">
    <div class="intro__number">01</div>
    <div class="intro__content">
      <span class="tag">Our Philosophy</span>
      <h2>Exceptional properties,<br/>extraordinary experiences</h2>
      <div class="line"></div>
      <p>Each villa in our collection has been personally selected for its architectural distinction, prime location, and commitment to guest experience. We don't just offer accommodation — we curate journeys.</p>
      <p class="intro__subtext">All properties are independently verified and also listed on Airbnb with Superhost status.</p>
      <a href="/croatia-rentals/about/" class="link">Discover our story <span>→</span></a>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="stat reveal">
      <span class="stat__number">4.98</span>
      <span class="stat__label">Airbnb Rating</span>
    </div>
    <div class="stat reveal">
      <span class="stat__number">500+</span>
      <span class="stat__label">5-Star Reviews</span>
    </div>
    <div class="stat reveal">
      <span class="stat__number">25+</span>
      <span class="stat__label">Curated Villas</span>
    </div>
    <div class="stat reveal">
      <span class="stat__number">98%</span>
      <span class="stat__label">Repeat Guests</span>
    </div>
  </section>

  <!-- Villas -->
  <section class="villas">
    <div class="villas__header reveal">
      <div class="villas__header-left">
        <span class="intro__number">02</span>
        <div>
          <span class="tag">The Collection</span>
          <h2>Selected Villas</h2>
        </div>
      </div>
      <a href="/croatia-rentals/villas/" class="link">View All <span>→</span></a>
    </div>
    <div class="villas__grid">
      {villas.map((villa, i) => (
        <div class="villa-card reveal" style={`transition-delay: ${i * 100}ms`}>
          <a href={`/croatia-rentals/villas/${villa.slug}/`} class="villa-card__image">
            <img src={villa.image} alt={villa.name} loading="lazy" />
            <div class="villa-card__badges">
              <span class="villa-card__badge">Superhost</span>
              <span class="villa-card__rating">★ 4.98</span>
            </div>
            <div class="villa-card__overlay">
              <span>View Details</span>
            </div>
          </a>
          <div class="villa-card__info">
            <span class="tag">{villa.location}</span>
            <h3>{villa.name}</h3>
            <div class="villa-card__meta">
              <span class="villa-card__price">From €{villa.price}</span>
              <span class="villa-card__unit">/ night</span>
            </div>
            <div class="villa-card__actions">
              <a href={`/croatia-rentals/villas/${villa.slug}/`} class="villa-card__link">View Details</a>
              <a href={villa.airbnb} target="_blank" class="villa-card__airbnb">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.42 0 5.82 1.96 4.63 4.38c-.6 1.21-.93 2.6-.93 4.1 0 3.04 1.67 5.8 3.17 7.94.49.7.98 1.35 1.43 1.96.5.68.95 1.3 1.31 1.87.37.58.64 1.1.79 1.52.16.46.3.98.41 1.52.12.54.21 1.09.27 1.63.06.54.09 1.07.09 1.58 0 .4-.02.78-.07 1.13-.05.36-.12.69-.22.98-.1.3-.22.56-.37.78s-.32.4-.52.52c-.2.13-.43.2-.67.2-.24 0-.47-.07-.67-.2-.2-.12-.37-.3-.52-.52s-.27-.48-.37-.78c-.1-.29-.17-.62-.22-.98-.05-.35-.07-.73-.07-1.13 0-.51.03-1.04.09-1.58.06-.54.15-1.09.27-1.63.11-.54.25-1.06.41-1.52.15-.42.42-.94.79-1.52.36-.57.81-1.19 1.31-1.87.45-.61.94-1.26 1.43-1.96 1.5-2.14 3.17-4.9 3.17-7.94 0-1.5-.33-2.89-.93-4.1C18.18 1.96 15.58 0 12 0z"/></svg>
                Airbnb
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Destinations -->
  <section class="destinations">
    <div class="destinations__header reveal">
      <span class="intro__number">03</span>
      <div>
        <span class="tag">Explore</span>
        <h2>Destinations</h2>
      </div>
    </div>
    <div class="destinations__grid">
      {destinations.map((dest, i) => (
        <div class="dest-card reveal" style={`transition-delay: ${i * 100}ms`}>
          <img src={dest.image} alt={dest.name} loading="lazy" />
          <div class="dest-card__content">
            <span class="dest-card__tagline">{dest.tagline}</span>
            <h3>{dest.name}</h3>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="experience">
    <div class="experience__image">
      <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=1000&q=85" alt="Croatian coast" class="parallax-img" />
    </div>
    <div class="experience__content reveal">
      <span class="intro__number">04</span>
      <span class="tag">The Experience</span>
      <h2>More than a stay.<br/><em>A memory.</em></h2>
      <div class="line"></div>
      <p>From the moment you arrive, our dedicated concierge ensures every detail is perfect. Private chefs, yacht charters, exclusive excursions — whatever you desire, we orchestrate it seamlessly.</p>
      <div class="experience__trust">
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          <span>Verified Host</span>
        </div>
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span>Superhost</span>
        </div>
        <div class="trust-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>24/7 Support</span>
        </div>
      </div>
      <a href="/croatia-rentals/about/" class="link">Discover our services <span>→</span></a>
    </div>
  </section>

  <!-- Services -->
  <section class="services">
    <div class="services__header reveal">
      <span class="intro__number">05</span>
      <div>
        <span class="tag">White Glove</span>
        <h2>Our Services</h2>
      </div>
    </div>
    <div class="services__grid">
      <div class="service reveal">
        <span class="service__icon">🛎️</span>
        <h4>Concierge</h4>
        <p>24/7 dedicated support for reservations, recommendations, and every need during your stay.</p>
      </div>
      <div class="service reveal">
        <span class="service__icon">👨‍🍳</span>
        <h4>Private Chef</h4>
        <p>Authentic Croatian cuisine prepared by acclaimed chefs in the comfort of your villa.</p>
      </div>
      <div class="service reveal">
        <span class="service__icon">⛵</span>
        <h4>Yacht Charter</h4>
        <p>Explore hidden islands and secluded coves aboard a luxury private yacht.</p>
      </div>
      <div class="service reveal">
        <span class="service__icon">🚗</span>
        <h4>Transfers</h4>
        <p>Seamless airport pickups and luxury transportation throughout your journey.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials">
    <div class="testimonials__header reveal">
      <span class="intro__number">06</span>
      <div>
        <span class="tag">Reviews</span>
        <h2>Guest Experiences</h2>
      </div>
      <div class="testimonials__rating">
        <span class="testimonials__stars">★★★★★</span>
        <span class="testimonials__score">4.98 on Airbnb</span>
      </div>
    </div>
    <div class="testimonials__grid">
      {testimonials.map((t, i) => (
        <div class="testimonial reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="testimonial__stars">{"★".repeat(t.rating)}</div>
          <p>{t.text}</p>
          <div class="testimonial__author">
            <strong>{t.author}</strong>
            <span>{t.from}</span>
          </div>
          <span class="testimonial__source">via Airbnb</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Instagram -->
  <section class="instagram">
    <div class="instagram__header reveal">
      <span class="intro__number">07</span>
      <div>
        <span class="tag">Follow Along</span>
        <h2>@adriatic.villas</h2>
      </div>
    </div>
    <div class="instagram__grid">
      <div class="insta-img reveal"><img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img reveal"><img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img reveal"><img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img reveal"><img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&q=80" alt="" loading="lazy" /></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta reveal">
    <span class="tag">Ready?</span>
    <h2>Begin your journey</h2>
    <div class="line" style="margin: 24px auto;"></div>
    <p>Book directly with us for the best rates, or find us on Airbnb.</p>
    <div class="cta__buttons">
      <a href="/croatia-rentals/contact/" class="btn btn--fill">Get in Touch</a>
      <a href="https://airbnb.com" target="_blank" class="btn btn--outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.42 0 5.82 1.96 4.63 4.38c-.6 1.21-.93 2.6-.93 4.1 0 3.04 1.67 5.8 3.17 7.94.49.7.98 1.35 1.43 1.96.5.68.95 1.3 1.31 1.87.37.58.64 1.1.79 1.52.16.46.3.98.41 1.52.12.54.21 1.09.27 1.63.06.54.09 1.07.09 1.58 0 .4-.02.78-.07 1.13-.05.36-.12.69-.22.98-.1.3-.22.56-.37.78s-.32.4-.52.52c-.2.13-.43.2-.67.2-.24 0-.47-.07-.67-.2-.2-.12-.37-.3-.52-.52s-.27-.48-.37-.78c-.1-.29-.17-.62-.22-.98-.05-.35-.07-.73-.07-1.13 0-.51.03-1.04.09-1.58.06-.54.15-1.09.27-1.63.11-.54.25-1.06.41-1.52.15-.42.42-.94.79-1.52.36-.57.81-1.19 1.31-1.87.45-.61.94-1.26 1.43-1.96 1.5-2.14 3.17-4.9 3.17-7.94 0-1.5-.33-2.89-.93-4.1C18.18 1.96 15.58 0 12 0z"/></svg>
        View on Airbnb
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    min-height: 100vh;
    padding-top: 80px;
  }
  
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 10%;
  }
  
  .hero__tag-line {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  
  .hero__divider {
    width: 40px;
    height: 1px;
    background: var(--gold);
  }
  
  .hero__content h1 {
    font-size: clamp(44px, 6vw, 76px);
    line-height: 1.05;
    margin: 24px 0;
  }
  
  .hero__content h1 em {
    font-style: italic;
    color: var(--gold);
  }
  
  .hero__content p {
    font-size: 16px;
    color: var(--gray);
    max-width: 380px;
    margin-bottom: 40px;
    line-height: 1.9;
  }
  
  .hero__buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  
  .btn--outline {
    background: transparent;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  
  .btn--outline svg {
    transition: transform 0.3s;
  }
  
  .btn--outline:hover svg {
    transform: scale(1.1);
  }
  
  .hero__image {
    position: relative;
    overflow: hidden;
  }
  
  .hero__image-wrapper {
    height: 100%;
    overflow: hidden;
  }
  
  .hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .hero__badge {
    position: absolute;
    top: 40px;
    left: 40px;
    background: var(--white);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  
  .hero__badge-rating {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--gold);
  }
  
  .hero__badge-text {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
  }
  
  .hero__scroll {
    position: absolute;
    bottom: 40px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--white);
  }
  
  .hero__scroll span {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }
  
  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: var(--white);
    animation: scrollLine 2s ease-in-out infinite;
  }
  
  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.5; }
  }
  
  /* Press */
  .press {
    display: flex;
    justify-content: center;
    gap: 80px;
    padding: 60px 5%;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  
  .press__item {
    text-align: center;
  }
  
  .press__name {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gray);
    margin-bottom: 8px;
  }
  
  .press__quote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--black);
  }
  
  /* Intro */
  .intro {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 60px;
    padding: 180px 10%;
    max-width: 1100px;
    margin: 0 auto;
  }
  
  .intro__number {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    color: var(--gold);
    padding-top: 4px;
  }
  
  .intro__content h2 {
    font-size: clamp(32px, 4vw, 48px);
    margin-bottom: 0;
    line-height: 1.2;
  }
  
  .intro__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 2;
    max-width: 540px;
    margin-bottom: 16px;
  }
  
  .intro__subtext {
    font-size: 14px !important;
    font-style: italic;
    opacity: 0.8;
  }
  
  .link {
    font-size: 13px;
    color: var(--black);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s;
    margin-top: 16px;
  }
  
  .link span {
    transition: transform 0.3s;
  }
  
  .link:hover {
    color: var(--gold);
  }
  
  .link:hover span {
    transform: translateX(4px);
  }
  
  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(0,0,0,0.08);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  
  .stat {
    padding: 80px 40px;
    text-align: center;
    border-right: 1px solid rgba(0,0,0,0.08);
    transition: background 0.5s;
  }
  
  .stat:last-child { border-right: none; }
  
  .stat:hover {
    background: var(--light);
  }
  
  .stat__number {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 56px;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  
  .stat__label {
    font-size: 11px;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  
  /* Villas */
  .villas {
    padding: 140px 5%;
    background: var(--light);
  }
  
  .villas__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 80px;
    padding: 0 5%;
  }
  
  .villas__header-left {
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }
  
  .villas__header h2 {
    font-size: 32px;
    margin-top: 8px;
  }
  
  .villas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    padding: 0 5%;
  }
  
  .villa-card__image {
    position: relative;
    display: block;
    aspect-ratio: 3/4;
    overflow: hidden;
    margin-bottom: 24px;
  }
  
  .villa-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
