---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__media">
      <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=2000&q=90&auto=format" alt="Luxury Croatian villa at sunset" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="hero__tag">Curated Croatian Estates</div>
      <h1 class="hero__title">Where the Adriatic Meets Home</h1>
      <p class="hero__desc">
        A private collection of exceptional villas along Croatia's most coveted coastline. 
        Discover the art of Mediterranean living.
      </p>
      <div class="hero__actions">
        <a href="/estates" class="btn btn--primary">Explore Estates</a>
        <a href="#tour" class="btn btn--outline-light">Virtual Tour</a>
      </div>
    </div>
    <div class="hero__scroll">
      <span>Scroll</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
        <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1"/>
        <circle cx="8" cy="8" r="2" fill="currentColor"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="intro__text reveal-on-scroll">
      <span class="intro__tag">Our Story</span>
      <h2>A legacy of <em>Mediterranean</em> elegance</h2>
      <p>
        For over a decade, we've curated the finest private estates along the Dalmatian Coast. 
        Each property is chosen for its exceptional character, breathtaking setting, and the 
        promise of unforgettable moments.
      </p>
      <div class="intro__stats">
        <div class="intro__stat">
          <div class="intro__stat-num">48</div>
          <div class="intro__stat-label">Curated Estates</div>
        </div>
        <div class="intro__stat">
          <div class="intro__stat-num">12</div>
          <div class="intro__stat-label">Years of Excellence</div>
        </div>
        <div class="intro__stat">
          <div class="intro__stat-num">98%</div>
          <div class="intro__stat-label">Guest Satisfaction</div>
        </div>
      </div>
      <a href="/about" class="btn btn--outline">Learn More</a>
    </div>
    <div class="intro__images reveal-on-scroll">
      <div class="intro__img">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=85&auto=format" alt="Villa exterior" loading="lazy" />
      </div>
      <div class="intro__img">
        <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=85&auto=format" alt="Villa interior" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Estates -->
  <section class="estates" id="estates">
    <div class="estates__header">
      <div>
        <span class="estates__tag">The Collection</span>
        <h2>Featured Estates</h2>
      </div>
      <a href="/estates" class="estates__link">View All Estates →</a>
    </div>
    <div class="estates__grid stagger-reveal">
      <article class="estate-card">
        <a href="/estates/villa-pietra">
          <div class="estate-card__image">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85&auto=format" alt="Villa Pietra" loading="lazy" />
            <span class="estate-card__tag">Signature</span>
          </div>
          <div class="estate-card__content">
            <span class="estate-card__location">Dubrovnik · Old Town</span>
            <h3 class="estate-card__title">Villa Pietra</h3>
            <p class="estate-card__desc">Historic stone villa with panoramic views of the ancient city walls.</p>
            <div class="estate-card__details">
              <span>4 Suites</span>
              <span>280 m²</span>
              <span>Sea View</span>
            </div>
            <div class="estate-card__footer">
              <span class="estate-card__price">From €890<small>/night</small></span>
              <span class="estate-card__link">View Estate →</span>
            </div>
          </div>
        </a>
      </article>
      
      <article class="estate-card">
        <a href="/estates/casa-adriatica">
          <div class="estate-card__image">
            <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85&auto=format" alt="Casa Adriatica" loading="lazy" />
            <span class="estate-card__tag">Waterfront</span>
          </div>
          <div class="estate-card__content">
            <span class="estate-card__location">Split · Diocletian</span>
            <h3 class="estate-card__title">Casa Adriatica</h3>
            <p class="estate-card__desc">Modern penthouse in a restored palace, steps from historic sites.</p>
            <div class="estate-card__details">
              <span>3 Suites</span>
              <span>185 m²</span>
              <span>Rooftop Terrace</span>
            </div>
            <div class="estate-card__footer">
              <span class="estate-card__price">From €650<small>/night</small></span>
              <span class="estate-card__link">View Estate →</span>
            </div>
          </div>
        </a>
      </article>
      
      <article class="estate-card">
        <a href="/estates/villa-lavanda">
          <div class="estate-card__image">
            <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=85&auto=format" alt="Villa Lavanda" loading="lazy" />
            <span class="estate-card__tag">Island</span>
          </div>
          <div class="estate-card__content">
            <span class="estate-card__location">Hvar · Lavender Bay</span>
            <h3 class="estate-card__title">Villa Lavanda</h3>
            <p class="estate-card__desc">Secluded estate surrounded by lavender fields with infinity pool.</p>
            <div class="estate-card__details">
              <span>5 Suites</span>
              <span>420 m²</span>
              <span>Infinity Pool</span>
            </div>
            <div class="estate-card__footer">
              <span class="estate-card__price">From €1,450<small>/night</small></span>
              <span class="estate-card__link">View Estate →</span>
            </div>
          </div>
        </a>
      </article>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="services">
    <div class="services__header">
      <span class="services__tag">Premium Services</span>
      <h2>Beyond Accommodation</h2>
      <p>Every stay includes our signature concierge service, ensuring each moment is crafted to perfection.</p>
    </div>
    <div class="services__grid stagger-reveal">
      <div class="service">
        <div class="service__icon">🛥️</div>
        <h4>Private Yacht Charter</h4>
        <p>Explore hidden islands and secluded coves aboard our curated fleet of luxury vessels.</p>
      </div>
      <div class="service">
        <div class="service__icon">👨‍🍳</div>
        <h4>In-Villa Dining</h4>
        <p>Private chefs prepare bespoke menus featuring the finest Dalmatian ingredients.</p>
      </div>
      <div class="service">
        <div class="service__icon">🎭</div>
        <h4>Cultural Journeys</h4>
        <p>Exclusive access to historical sites, artisan workshops, and local traditions.</p>
      </div>
      <div class="service">
        <div class="service__icon">✨</div>
        <h4>Concierge 24/7</h4>
        <p>Your dedicated lifestyle manager handles every detail, from transfers to reservations.</p>
      </div>
    </div>
  </section>

  <!-- Tour -->
  <section class="tour" id="tour">
    <div class="tour__content reveal-on-scroll">
      <span class="tour__tag">Virtual Experience</span>
      <h2>Experience before you <em>arrive</em></h2>
      <p>
        Walk through our estates from anywhere in the world. Our immersive 3D tours 
        reveal every corner, every view, every possibility.
      </p>
      <ul class="tour__list">
        <li>Photorealistic 360° walkthroughs</li>
        <li>Interactive floor plans</li>
        <li>Day and twilight lighting</li>
        <li>Neighborhood exploration</li>
      </ul>
      <a href="#" class="btn btn--primary">Begin Virtual Tour</a>
    </div>
    <div class="tour__media">
      <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1000&q=85&auto=format" alt="Villa interior" loading="lazy" />
      <div class="tour__play">▶</div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta__content">
      <h2>Ready to discover your perfect Croatian escape?</h2>
      <p>Our specialists are here to curate an unforgettable experience tailored to you.</p>
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  
  .hero__media {
    position: absolute;
    inset: 0;
  }
  
  .hero__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    animation: reveal 1.5s ease forwards;
  }
  
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(31, 31, 31, 0.85) 0%,
      rgba(31, 31, 31, 0.4) 50%,
      rgba(31, 31, 31, 0.2) 100%
    );
  }
  
  .hero__content {
    position: relative;
    z-index: 2;
    padding: 0 5% 10%;
    color: var(--white);
    max-width: 800px;
    animation: fadeUp 1s ease 0.5s both;
  }
  
  .hero__tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  
  .hero__tag::before {
    content: '';
    width: 48px; height: 1px;
    background: var(--sand);
  }
  
  .hero__title {
    font-size: clamp(42px, 7vw, 80px);
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--white);
  }
  
  .hero__desc {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    max-width: 500px;
    margin-bottom: 40px;
    line-height: 1.7;
  }
  
  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  
  .btn--outline-light {
    background: transparent;
    color: var(--white);
    border: 1.5px solid rgba(255,255,255,0.5);
  }
  
  .btn--outline-light:hover {
    background: var(--white);
    color: var(--charcoal);
    border-color: var(--white);
  }
  
  .hero__scroll {
    position: absolute;
    bottom: 5%;
    right: 5%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--sand);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: float 3s ease infinite;
  }
  
  .hero__scroll span {
    writing-mode: vertical-rl;
  }
  
  /* Intro */
  .intro {
    padding: 140px 5%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
  }
  
  .intro__tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 16px;
    display: block;
  }
  
  .intro__text h2 {
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.2;
    margin-bottom: 24px;
    color: var(--charcoal);
  }
  
  .intro__text h2 em {
    font-style: italic;
    color: var(--olive);
  }
  
  .intro__text p {
    font-size: 17px;
    color: var(--charcoal-light);
    max-width: 480px;
    margin-bottom: 40px;
    line-height: 1.8;
  }
  
  .intro__stats {
    display: flex;
    gap: 48px;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  
  .intro__stat-num {
    font-family: 'Instrument Serif', serif;
    font-size: 42px;
    color: var(--olive);
    line-height: 1;
  }
  
  .intro__stat-label {
    font-size: 13px;
    color: var(--charcoal-light);
    margin-top: 8px;
  }
  
  .intro__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  
  .intro__img {
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  
  .intro__img:first-child {
    margin-top: 48px;
  }
  
  .intro__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  
  .intro__img:hover img {
    transform: scale(1.05);
  }
  
  /* Estates */
  .estates {
    padding: 100px 5% 140px;
    background: var(--linen);
  }
  
  .estates__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
  }
  
  .estates__tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 12px;
    display: block;
  }
  
  .estates__header h2 {
    font-size: clamp(32px, 4vw, 48px);
    color: var(--charcoal);
  }
  
  .estates__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--olive);
    border-bottom: 1px solid var(--olive);
    padding-bottom: 4px;
    transition: color 0.3s ease;
  }
  
  .estates__link:hover {
    color: var(--charcoal);
    border-color: var(--charcoal);
  }
  
  .estates__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  
  .estate-card {
    background: var(--white);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .estate-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.08);
  }
  
  .estate-card a {
    display: block;
  }
  
  .estate-card__image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .estate-card__image img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .estate-card:hover .estate-card__image img {
    transform: scale(1.05);
  }
  
  .estate-card__tag {
    position: absolute;
    top: 16px; left: 16px;
    padding: 8px 16px;
    background: var(--terracotta);
    color: var(--white);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  
  .estate-card__content {
    padding: 28px;
  }
  
  .estate-card__location {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 8px;
    display: block;
  }
  
  .estate-card__title {
    font-size: 24px;
    color: var(--charcoal);
    margin-bottom: 12px;
  }
  
  .estate-card__desc {
    font-size: 15px;
    color: var(--charcoal-light);
    margin-bottom: 16px;
    line-height: 1.6;
  }
  
  .estate-card__details {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: var(--stone);
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  
  .estate-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .estate-card__price {
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    color: var(--charcoal);
  }
  
  .estate-card__price small {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: var(--stone);
  }
  
  .estate-card__link {
    font-size: 13px;
    font-weight: 500;
    color: var(--olive);
    transition: color 0.3s ease;
  }
  
  .estate-card:hover .estate-card__link {
    color: var(--charcoal);
  }
  
  /* Services */
  .services {
    padding: 140px 5%;
    background: var(--olive);
    color: var(--cream);
  }
  
  .services__header {
    max-width: 600px;
    margin-bottom: 60px;
  }
  
  .services__tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 16px;
    display: block;
  }
  
  .services__header h2 {
    font-size: clamp(32px, 4vw, 48px);
    margin-bottom: 20px;
    color: var(--cream);
  }
  
  .services__header p {
    font-size: 17px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
  }
  
  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  
  .service {
    padding: 40px 32px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    transition: background 0.3s ease;
  }
  
  .service:hover {
    background: rgba(255,255,255,0.12);
  }
  
  .service__icon {
    font-size: 32px;
    margin-bottom: 20px;
  }
  
  .service h4 {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--cream);
  }
  
  .service p {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
  }
  
  /* Tour */
  .tour {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  
  .tour__content {
    padding: 100px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--cream);
  }
  
  .tour__tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 16px;
    display: block;
  }
  
  .tour__content h2 {
    font-size: clamp(32px, 3.5vw, 44px);
    margin-bottom: 20px;
    color: var(--charcoal);
  }
  
  .tour__content h2 em {
    font-style: italic;
    color: var(--olive);
  }
  
  .tour__content > p {
    font-size: 17px;
    color: var(--charcoal-light);
    margin-bottom: 32px;
    max-width: 420px;
    line-height: 1.7;
  }
  
  .tour__list {
    list-style: none;
    margin-bottom: 40px;
  }
  
  .tour__list li {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    font-size: 15px;
    color: var(--charcoal);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  
  .tour__list li::before {
    content: '→';
    color: var(--olive);
    font-weight: 500;
  }
  
  .tour__media {
    position: relative;
    overflow: hidden;
  }
  
  .tour__media img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  
  .tour__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 90px; height: 90px;
    border: 2px solid var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    background: rgba(0,0,0,0.2);
  }
  
  .tour__play:hover {
    background: var(--white);
    color: var(--charcoal);
    transform: translate(-50%, -50%) scale(1.1);
  }
  
  /* CTA */
  .cta {
    padding: 120px 5%;
    background: var(--linen);
    text-align: center;
  }
  
  .cta__content {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .cta__content h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    color: var(--charcoal);
    margin-bottom: 16px;
  }
  
  .cta__content p {
    font-size: 17px;
    color: var(--charcoal-light);
    margin-bottom: 32px;
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .intro { grid-template-columns: 1fr; gap: 60px; }
    .intro__images { order: -1; }
    .estates__grid { grid-template-columns: repeat(2, 1fr); }
    .services__grid { grid-template-columns: repeat(2, 1fr); }
    .tour { grid-template-columns: 1fr; }
    .tour__content { padding: 80px 5%; }
    .tour__media { min-height: 500px; }
  }
  
  @media (max-width: 768px) {
    .hero__content { padding: 0 5% 15%; }
    .hero__scroll { display: none; }
    .intro { padding: 80px 5%; }
    .intro__stats { flex-wrap: wrap; gap: 32px; }
    .estates { padding: 80px 5%; }
    .estates__header { flex-direction: column; align-items: flex-start; gap: 20px; }
    .estates__grid { grid-template-columns: 1fr; }
    .services { padding: 80px 5%; }
    .services__grid { grid-template-columns: 1fr; }
    .cta { padding: 80px 5%; }
  }
</style>
