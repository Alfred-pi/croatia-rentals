---
// Dalmatia — Curated Croatian Estates
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dalmatia | Curated Croatian Estates</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    @keyframes fadeUp { 
      from { opacity: 0; transform: translateY(30px); } 
      to { opacity: 1; transform: translateY(0); } 
    }
    @keyframes float { 
      0%, 100% { transform: translateY(0); } 
      50% { transform: translateY(-10px); } 
    }
    @keyframes reveal {
      from { clip-path: inset(0 100% 0 0); }
      to { clip-path: inset(0 0 0 0); }
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    :root {
      --olive: #4A5043;
      --olive-light: #6B7362;
      --sand: #C4B7A6;
      --cream: #F7F5F0;
      --linen: #EDE8E0;
      --charcoal: #2C2C2C;
      --stone: #8B8578;
      --terracotta: #C17F59;
      --white: #FFFFFF;
    }
    
    html { scroll-behavior: smooth; }
    
    body {
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      color: var(--charcoal);
      background: var(--cream);
      line-height: 1.7;
      cursor: none;
      overflow-x: hidden;
    }
    
    /* Custom Cursor */
    .cursor {
      width: 20px;
      height: 20px;
      border: 1.5px solid var(--olive);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      transition: transform 0.15s ease, background 0.2s ease;
      mix-blend-mode: difference;
    }
    
    .cursor.hover {
      transform: scale(2.5);
      background: var(--olive);
      border-color: var(--olive);
    }
    
    h1, h2, h3 { 
      font-family: 'Instrument Serif', serif; 
      font-weight: 400;
      letter-spacing: -0.02em;
    }
    
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    
    /* Navigation */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 32px 5%;
      mix-blend-mode: difference;
    }
    
    .nav__logo {
      font-family: 'Instrument Serif', serif;
      font-size: 24px;
      color: var(--white);
      font-style: italic;
    }
    
    .nav__links {
      display: flex;
      gap: 48px;
    }
    
    .nav__links a {
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--white);
      position: relative;
    }
    
    .nav__links a::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0;
      width: 0; height: 1px;
      background: var(--white);
      transition: width 0.3s ease;
    }
    
    .nav__links a:hover::after { width: 100%; }
    
    /* Hero - Cinematic */
    .hero {
      height: 100vh;
      position: relative;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    
    .hero__media {
      position: absolute;
      inset: 0;
    }
    
    .hero__media img {
      width: 100%; height: 100%;
      object-fit: cover;
      animation: reveal 1.5s ease forwards;
    }
    
    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(44, 44, 44, 0.7) 0%,
        rgba(44, 44, 44, 0.2) 50%,
        transparent 100%
      );
    }
    
    .hero__content {
      position: relative;
      z-index: 2;
      padding: 0 5% 8%;
      color: var(--white);
      max-width: 800px;
      animation: fadeUp 1s ease 0.5s both;
    }
    
    .hero__tag {
      font-size: 11px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--sand);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .hero__tag::before {
      content: '';
      width: 48px; height: 1px;
      background: var(--sand);
    }
    
    .hero__title {
      font-size: clamp(48px, 8vw, 96px);
      line-height: 1;
      margin-bottom: 32px;
      font-style: italic;
    }
    
    .hero__desc {
      font-size: 18px;
      color: rgba(255,255,255,0.7);
      max-width: 480px;
      margin-bottom: 48px;
    }
    
    .hero__cta {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      font-size: 13px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      padding: 20px 0;
      border-bottom: 1px solid rgba(255,255,255,0.3);
      transition: all 0.3s ease;
    }
    
    .hero__cta:hover {
      gap: 24px;
      border-color: var(--white);
    }
    
    .hero__scroll {
      position: absolute;
      bottom: 5%;
      right: 5%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      color: var(--sand);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      animation: float 3s ease infinite;
    }
    
    .hero__scroll span {
      writing-mode: vertical-rl;
    }
    
    /* Intro */
    .intro {
      padding: 160px 5%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 120px;
      align-items: center;
    }
    
    .intro__text h2 {
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.15;
      margin-bottom: 32px;
    }
    
    .intro__text h2 em {
      font-style: italic;
      color: var(--olive);
    }
    
    .intro__text p {
      font-size: 17px;
      color: var(--stone);
      max-width: 440px;
      margin-bottom: 48px;
    }
    
    .intro__stats {
      display: flex;
      gap: 48px;
    }
    
    .intro__stat {
      text-align: left;
    }
    
    .intro__stat-num {
      font-family: 'Instrument Serif', serif;
      font-size: 48px;
      color: var(--olive);
      line-height: 1;
    }
    
    .intro__stat-label {
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--stone);
      margin-top: 8px;
    }
    
    .intro__images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    
    .intro__img {
      aspect-ratio: 3/4;
      overflow: hidden;
    }
    
    .intro__img:first-child {
      margin-top: 60px;
    }
    
    .intro__img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.8s ease;
    }
    
    .intro__img:hover img {
      transform: scale(1.05);
    }
    
    /* Estates - Editorial Layout */
    .estates {
      padding: 80px 0 160px;
      background: var(--linen);
    }
    
    .estates__header {
      padding: 0 5%;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 80px;
    }
    
    .estates__header h2 {
      font-size: clamp(36px, 5vw, 56px);
    }
    
    .estates__header a {
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--olive);
      border-bottom: 1px solid var(--olive);
      padding-bottom: 4px;
    }
    
    /* Horizontal Scroll */
    .estates__scroll {
      display: flex;
      gap: 40px;
      padding: 0 5%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    
    .estates__scroll::-webkit-scrollbar { display: none; }
    
    .estate {
      flex: 0 0 420px;
      scroll-snap-align: start;
    }
    
    .estate__image {
      aspect-ratio: 3/4;
      overflow: hidden;
      margin-bottom: 24px;
      position: relative;
    }
    
    .estate__image img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    
    .estate:hover .estate__image img {
      transform: scale(1.05);
    }
    
    .estate__tag {
      position: absolute;
      top: 20px; left: 20px;
      padding: 8px 16px;
      background: var(--terracotta);
      color: var(--white);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    
    .estate__location {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--olive);
      margin-bottom: 8px;
    }
    
    .estate__title {
      font-size: 26px;
      margin-bottom: 12px;
    }
    
    .estate__details {
      display: flex;
      gap: 24px;
      font-size: 14px;
      color: var(--stone);
      margin-bottom: 16px;
    }
    
    .estate__price {
      font-family: 'Instrument Serif', serif;
      font-size: 22px;
      color: var(--charcoal);
    }
    
    .estate__price span {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      color: var(--stone);
    }
    
    /* Services */
    .services {
      padding: 160px 5%;
      background: var(--olive);
      color: var(--cream);
    }
    
    .services__header {
      max-width: 600px;
      margin-bottom: 80px;
    }
    
    .services__header h2 {
      font-size: clamp(36px, 5vw, 56px);
      margin-bottom: 24px;
      color: var(--cream);
    }
    
    .services__header p {
      font-size: 17px;
      color: var(--sand);
    }
    
    .services__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
    }
    
    .service {
      background: rgba(255,255,255,0.05);
      padding: 48px 32px;
      transition: background 0.3s ease;
    }
    
    .service:hover {
      background: rgba(255,255,255,0.1);
    }
    
    .service__num {
      font-family: 'Instrument Serif', serif;
      font-size: 48px;
      color: var(--sand);
      opacity: 0.5;
      margin-bottom: 24px;
    }
    
    .service h4 {
      font-family: 'Outfit', sans-serif;
      font-size: 18px;
      font-weight: 400;
      margin-bottom: 12px;
    }
    
    .service p {
      font-size: 14px;
      color: var(--sand);
      line-height: 1.6;
    }
    
    /* Tour */
    .tour {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
    
    .tour__content {
      padding: 120px 80px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: var(--cream);
    }
    
    .tour__content h2 {
      font-size: clamp(36px, 4vw, 48px);
      margin-bottom: 24px;
    }
    
    .tour__content h2 em {
      font-style: italic;
      color: var(--olive);
    }
    
    .tour__content > p {
      font-size: 17px;
      color: var(--stone);
      margin-bottom: 40px;
      max-width: 400px;
    }
    
    .tour__list {
      list-style: none;
      margin-bottom: 48px;
    }
    
    .tour__list li {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 0;
      font-size: 15px;
      color: var(--charcoal);
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    
    .tour__list li::before {
      content: '→';
      color: var(--olive);
    }
    
    .tour__btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 20px 40px;
      background: var(--charcoal);
      color: var(--cream);
      font-size: 13px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: background 0.3s ease;
      width: fit-content;
    }
    
    .tour__btn:hover {
      background: var(--olive);
    }
    
    .tour__media {
      position: relative;
      overflow: hidden;
    }
    
    .tour__media img {
      width: 100%; height: 100%;
      object-fit: cover;
    }
    
    .tour__play {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 100px; height: 100px;
      border: 1px solid var(--cream);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--cream);
      font-size: 18px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .tour__play:hover {
      background: var(--cream);
      color: var(--charcoal);
      transform: translate(-50%, -50%) scale(1.1);
    }
    
    /* Contact */
    .contact {
      padding: 160px 5%;
      background: var(--cream);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 120px;
    }
    
    .contact__info h2 {
      font-size: clamp(36px, 5vw, 56px);
      margin-bottom: 24px;
    }
    
    .contact__info > p {
      font-size: 17px;
      color: var(--stone);
      margin-bottom: 48px;
      max-width: 400px;
    }
    
    .contact__detail {
      padding: 24px 0;
      border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    
    .contact__detail span {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--stone);
      display: block;
      margin-bottom: 8px;
    }
    
    .contact__detail a {
      font-size: 18px;
      color: var(--charcoal);
      transition: color 0.3s ease;
    }
    
    .contact__detail a:hover {
      color: var(--olive);
    }
    
    .contact__form {
      background: var(--linen);
      padding: 60px;
    }
    
    .contact__form h3 {
      font-size: 28px;
      margin-bottom: 40px;
    }
    
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    
    .form-group {
      margin-bottom: 24px;
    }
    
    .form-group label {
      display: block;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--stone);
      margin-bottom: 12px;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 16px 0;
      font-family: 'Outfit', sans-serif;
      font-size: 16px;
      font-weight: 300;
      border: none;
      border-bottom: 1px solid rgba(0,0,0,0.15);
      background: transparent;
      color: var(--charcoal);
      transition: border-color 0.3s ease;
    }
    
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--olive);
    }
    
    .form-group textarea {
      resize: none;
      height: 100px;
    }
    
    .contact__form button {
      width: 100%;
      padding: 20px;
      background: var(--charcoal);
      color: var(--cream);
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: background 0.3s ease;
      margin-top: 16px;
    }
    
    .contact__form button:hover {
      background: var(--olive);
    }
    
    /* Footer */
    .footer {
      padding: 80px 5%;
      background: var(--charcoal);
      color: var(--cream);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .footer__logo {
      font-family: 'Instrument Serif', serif;
      font-size: 24px;
      font-style: italic;
    }
    
    .footer__links {
      display: flex;
      gap: 48px;
    }
    
    .footer__links a {
      font-size: 13px;
      color: var(--sand);
      transition: color 0.3s ease;
    }
    
    .footer__links a:hover {
      color: var(--cream);
    }
    
    .footer__copy {
      font-size: 12px;
      color: var(--stone);
    }
    
    /* Responsive */
    @media (max-width: 1024px) {
      .intro { grid-template-columns: 1fr; gap: 80px; }
      .intro__images { order: -1; }
      .services__grid { grid-template-columns: repeat(2, 1fr); }
      .tour { grid-template-columns: 1fr; }
      .tour__content { padding: 80px 5%; }
      .tour__media { min-height: 500px; }
      .contact { grid-template-columns: 1fr; gap: 80px; }
    }
    
    @media (max-width: 768px) {
      body { cursor: auto; }
      .cursor { display: none; }
      .nav__links { display: none; }
      .hero__content { padding: 0 5% 15%; }
      .hero__scroll { display: none; }
      .intro { padding: 100px 5%; }
      .intro__stats { flex-wrap: wrap; gap: 32px; }
      .estate { flex: 0 0 300px; }
      .services { padding: 100px 5%; }
      .services__grid { grid-template-columns: 1fr; }
      .contact__form { padding: 40px 24px; }
      .form-row { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 32px; text-align: center; }
      .footer__links { flex-wrap: wrap; justify-content: center; }
    }
  </style>
</head>
<body>
  <div class="cursor"></div>

  <!-- Nav -->
  <nav class="nav">
    <a href="/" class="nav__logo">Dalmatia</a>
    <div class="nav__links">
      <a href="#estates">Estates</a>
      <a href="#services">Services</a>
      <a href="#tour">Virtual Tour</a>
      <a href="#contact">Inquire</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__media">
      <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=2000&q=90&auto=format" alt="Luxury Croatian villa at sunset" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="hero__tag">Curated Croatian Estates</div>
      <h1 class="hero__title">Where the Adriatic Meets Home</h1>
      <p class="hero__desc">
        A private collection of exceptional villas along Croatia's most coveted coastline. 
        Discover the art of Mediterranean living.
      </p>
      <a href="#estates" class="hero__cta">
        Explore the Collection
        <span>→</span>
      </a>
    </div>
    <div class="hero__scroll">
      <span>Scroll</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
        <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1"/>
        <circle cx="8" cy="8" r="2" fill="currentColor"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="intro__text">
      <h2>A legacy of <em>Mediterranean</em> elegance</h2>
      <p>
        For over a decade, we've curated the finest private estates along the Dalmatian Coast. 
        Each property is chosen for its exceptional character, breathtaking setting, and the 
        promise of unforgettable moments.
      </p>
      <div class="intro__stats">
        <div class="intro__stat">
          <div class="intro__stat-num">48</div>
          <div class="intro__stat-label">Curated Estates</div>
        </div>
        <div class="intro__stat">
          <div class="intro__stat-num">12</div>
          <div class="intro__stat-label">Years of Excellence</div>
        </div>
        <div class="intro__stat">
          <div class="intro__stat-num">98%</div>
          <div class="intro__stat-label">Guest Satisfaction</div>
        </div>
      </div>
    </div>
    <div class="intro__images">
      <div class="intro__img">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=85&auto=format" alt="Villa exterior" loading="lazy" />
      </div>
      <div class="intro__img">
        <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=85&auto=format" alt="Villa interior" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Estates -->
  <section class="estates" id="estates">
    <div class="estates__header">
      <h2>Featured Estates</h2>
      <a href="#">View All →</a>
    </div>
    <div class="estates__scroll">
      <article class="estate">
        <div class="estate__image">
          <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85&auto=format" alt="Villa Pietra" loading="lazy" />
          <span class="estate__tag">Signature</span>
        </div>
        <div class="estate__location">Dubrovnik · Old Town</div>
        <h3 class="estate__title">Villa Pietra</h3>
        <div class="estate__details">
          <span>4 Suites</span>
          <span>280 m²</span>
          <span>Sea View</span>
        </div>
        <div class="estate__price">€890 <span>/night</span></div>
      </article>
      
      <article class="estate">
        <div class="estate__image">
          <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85&auto=format" alt="Casa Adriatica" loading="lazy" />
          <span class="estate__tag">Waterfront</span>
        </div>
        <div class="estate__location">Split · Diocletian</div>
        <h3 class="estate__title">Casa Adriatica</h3>
        <div class="estate__details">
          <span>3 Suites</span>
          <span>185 m²</span>
          <span>Rooftop</span>
        </div>
        <div class="estate__price">€650 <span>/night</span></div>
      </article>
      
      <article class="estate">
        <div class="estate__image">
          <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=85&auto=format" alt="Villa Lavanda" loading="lazy" />
          <span class="estate__tag">Island</span>
        </div>
        <div class="estate__location">Hvar · Lavender Bay</div>
        <h3 class="estate__title">Villa Lavanda</h3>
        <div class="estate__details">
          <span>5 Suites</span>
          <span>420 m²</span>
          <span>Pool</span>
        </div>
