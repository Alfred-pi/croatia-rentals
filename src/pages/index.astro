---
import Layout from '../layouts/Layout.astro';

const villas = [
  { name: 'Villa Pietra', location: 'Dubrovnik', price: 890, image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85', slug: 'villa-pietra' },
  { name: 'Casa Blu', location: 'Hvar', price: 1200, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85', slug: 'casa-blu' },
  { name: 'Villa Oliva', location: 'Split', price: 750, image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85', slug: 'villa-oliva' },
];
---

<Layout title="ADRIATIC — Luxury Croatian Villas">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <span class="tag">Croatian Riviera</span>
      <h1>Where the<br/>Adriatic meets<br/>luxury</h1>
      <p>A curated collection of exceptional villas along Croatia's most coveted coastline.</p>
      <a href="/croatia-rentals/villas/" class="btn">Explore Villas</a>
    </div>
    <div class="hero__image">
      <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1400&q=90" alt="Luxury villa" />
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="intro__number">01</div>
    <div class="intro__content">
      <h2>Exceptional properties,<br/>extraordinary experiences</h2>
      <p>Each villa in our collection has been personally selected for its architectural distinction, prime location, and commitment to guest experience. From historic stone estates in Dubrovnik to contemporary retreats on Hvar.</p>
      <a href="/croatia-rentals/about/" class="link">Learn more →</a>
    </div>
  </section>

  <!-- Villas -->
  <section class="villas">
    <div class="villas__header">
      <span class="intro__number">02</span>
      <h2>Selected Villas</h2>
      <a href="/croatia-rentals/villas/" class="link">View All →</a>
    </div>
    <div class="villas__grid">
      {villas.map(villa => (
        <a href={`/croatia-rentals/villas/${villa.slug}/`} class="villa-card">
          <div class="villa-card__image">
            <img src={villa.image} alt={villa.name} loading="lazy" />
          </div>
          <div class="villa-card__info">
            <span class="tag">{villa.location}</span>
            <h3>{villa.name}</h3>
            <span class="villa-card__price">From €{villa.price}/night</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="services">
    <div class="services__header">
      <span class="intro__number">03</span>
      <h2>Our Services</h2>
    </div>
    <div class="services__grid">
      <div class="service">
        <h4>Concierge</h4>
        <p>24/7 dedicated support for all your needs during your stay.</p>
      </div>
      <div class="service">
        <h4>Private Chef</h4>
        <p>Authentic Croatian cuisine prepared in the comfort of your villa.</p>
      </div>
      <div class="service">
        <h4>Yacht Charter</h4>
        <p>Explore the islands aboard a luxury private yacht.</p>
      </div>
      <div class="service">
        <h4>Transfers</h4>
        <p>Seamless airport pickups and luxury transportation.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Begin your journey</h2>
    <p>Let us help you find the perfect Croatian retreat.</p>
    <a href="/croatia-rentals/contact/" class="btn btn--fill">Get in Touch</a>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    padding-top: 80px;
  }
  
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 10%;
  }
  
  .hero__content h1 {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.1;
    margin: 24px 0;
  }
  
  .hero__content p {
    font-size: 16px;
    color: var(--gray);
    max-width: 400px;
    margin-bottom: 48px;
    line-height: 1.8;
  }
  
  .hero__image {
    overflow: hidden;
  }
  
  .hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  /* Intro */
  .intro {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 60px;
    padding: 160px 10%;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .intro__number {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--gold);
    padding-top: 8px;
  }
  
  .intro__content h2 {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 24px;
    line-height: 1.3;
  }
  
  .intro__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    max-width: 600px;
    margin-bottom: 24px;
  }
  
  .link {
    font-size: 14px;
    color: var(--black);
    transition: color 0.3s;
  }
  
  .link:hover {
    color: var(--gold);
  }
  
  /* Villas */
  .villas {
    padding: 80px 5%;
    background: var(--light);
  }
  
  .villas__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
    padding: 0 5%;
  }
  
  .villas__header h2 {
    font-size: 28px;
    flex: 1;
  }
  
  .villas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    padding: 0 5%;
  }
  
  .villa-card {
    display: block;
  }
  
  .villa-card__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    margin-bottom: 20px;
  }
  
  .villa-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .villa-card:hover .villa-card__image img {
    transform: scale(1.05);
  }
  
  .villa-card__info h3 {
    font-size: 22px;
    margin: 8px 0;
  }
  
  .villa-card__price {
    font-size: 13px;
    color: var(--gray);
  }
  
  /* Services */
  .services {
    padding: 160px 10%;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .services__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .services__header h2 {
    font-size: 28px;
  }
  
  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }
  
  .service h4 {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 12px;
  }
  
  .service p {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.7;
  }
  
  /* CTA */
  .cta {
    text-align: center;
    padding: 160px 5%;
    background: var(--light);
  }
  
  .cta h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 16px;
  }
  
  .cta p {
    font-size: 16px;
    color: var(--gray);
    margin-bottom: 40px;
  }
  
  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero__content { padding: 120px 5% 60px; }
    .hero__image { height: 60vh; }
    .villas__grid { grid-template-columns: 1fr; gap: 48px; }
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media (max-width: 768px) {
    .intro { grid-template-columns: 1fr; gap: 24px; padding: 80px 5%; }
    .services { padding: 80px 5%; }
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
