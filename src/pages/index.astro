---
import Layout from '../layouts/Layout.astro';

const villas = [
  { name: 'Villa Pietra', location: 'Dubrovnik', price: 890, image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85', slug: 'villa-pietra' },
  { name: 'Casa Blu', location: 'Hvar', price: 1200, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85', slug: 'casa-blu' },
  { name: 'Villa Oliva', location: 'Split', price: 750, image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85', slug: 'villa-oliva' },
];

const destinations = [
  { name: 'Dubrovnik', tagline: 'Pearl of the Adriatic', image: 'https://images.unsplash.com/photo-1555990538-1e15d5b97d8d?w=600&q=85' },
  { name: 'Hvar', tagline: 'Island of endless sun', image: 'https://images.unsplash.com/photo-1534008897995-27a23e859048?w=600&q=85' },
  { name: 'Split', tagline: 'Ancient Roman splendor', image: 'https://images.unsplash.com/photo-1592499453756-ee2368f632ee?w=600&q=85' },
];

const testimonials = [
  { text: "An absolutely unforgettable experience. The villa exceeded all expectations.", author: "James & Sarah", from: "London" },
  { text: "We've traveled the world, but Croatia with Adriatic was truly special.", author: "The Martinez Family", from: "Miami" },
];
---

<Layout title="ADRIATIC — Luxury Croatian Villas">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <span class="tag">Croatian Riviera</span>
      <h1>Where the<br/>Adriatic meets<br/>luxury</h1>
      <p>A curated collection of exceptional villas along Croatia's most coveted coastline.</p>
      <a href="/croatia-rentals/villas/" class="btn">Explore Villas</a>
    </div>
    <div class="hero__image">
      <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1400&q=90" alt="Luxury villa" />
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="intro__number">01</div>
    <div class="intro__content">
      <h2>Exceptional properties,<br/>extraordinary experiences</h2>
      <p>Each villa in our collection has been personally selected for its architectural distinction, prime location, and commitment to guest experience. From historic stone estates in Dubrovnik to contemporary retreats on Hvar.</p>
      <a href="/croatia-rentals/about/" class="link">Learn more →</a>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="stat">
      <span class="stat__number">25+</span>
      <span class="stat__label">Luxury Villas</span>
    </div>
    <div class="stat">
      <span class="stat__number">6</span>
      <span class="stat__label">Destinations</span>
    </div>
    <div class="stat">
      <span class="stat__number">500+</span>
      <span class="stat__label">Happy Guests</span>
    </div>
    <div class="stat">
      <span class="stat__number">5★</span>
      <span class="stat__label">Average Rating</span>
    </div>
  </section>

  <!-- Villas -->
  <section class="villas">
    <div class="villas__header">
      <span class="intro__number">02</span>
      <h2>Selected Villas</h2>
      <a href="/croatia-rentals/villas/" class="link">View All →</a>
    </div>
    <div class="villas__grid">
      {villas.map(villa => (
        <a href={`/croatia-rentals/villas/${villa.slug}/`} class="villa-card">
          <div class="villa-card__image">
            <img src={villa.image} alt={villa.name} loading="lazy" />
          </div>
          <div class="villa-card__info">
            <span class="tag">{villa.location}</span>
            <h3>{villa.name}</h3>
            <span class="villa-card__price">From €{villa.price}/night</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Destinations -->
  <section class="destinations">
    <div class="destinations__header">
      <span class="intro__number">03</span>
      <h2>Destinations</h2>
    </div>
    <div class="destinations__grid">
      {destinations.map(dest => (
        <div class="dest-card">
          <img src={dest.image} alt={dest.name} loading="lazy" />
          <div class="dest-card__content">
            <h3>{dest.name}</h3>
            <p>{dest.tagline}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="experience">
    <div class="experience__image">
      <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=800&q=85" alt="Croatian coast" />
    </div>
    <div class="experience__content">
      <span class="intro__number">04</span>
      <h2>More than a stay.<br/>An experience.</h2>
      <p>From the moment you arrive, our dedicated concierge ensures every detail is perfect. Private chefs, yacht charters, exclusive excursions — whatever you desire, we make it happen.</p>
      <a href="/croatia-rentals/about/" class="link">Discover our services →</a>
    </div>
  </section>

  <!-- Services -->
  <section class="services">
    <div class="services__header">
      <span class="intro__number">05</span>
      <h2>Our Services</h2>
    </div>
    <div class="services__grid">
      <div class="service">
        <h4>Concierge</h4>
        <p>24/7 dedicated support for all your needs during your stay.</p>
      </div>
      <div class="service">
        <h4>Private Chef</h4>
        <p>Authentic Croatian cuisine prepared in the comfort of your villa.</p>
      </div>
      <div class="service">
        <h4>Yacht Charter</h4>
        <p>Explore the islands aboard a luxury private yacht.</p>
      </div>
      <div class="service">
        <h4>Transfers</h4>
        <p>Seamless airport pickups and luxury transportation.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials">
    <div class="testimonials__header">
      <span class="intro__number">06</span>
      <h2>What Our Guests Say</h2>
    </div>
    <div class="testimonials__grid">
      {testimonials.map(t => (
        <div class="testimonial">
          <p>"{t.text}"</p>
          <div class="testimonial__author">
            <strong>{t.author}</strong>
            <span>{t.from}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Instagram -->
  <section class="instagram">
    <div class="instagram__header">
      <span class="intro__number">07</span>
      <h2>Follow Our Journey</h2>
      <a href="https://instagram.com" target="_blank" class="link">@adriatic.villas →</a>
    </div>
    <div class="instagram__grid">
      <div class="insta-img"><img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img"><img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img"><img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=400&q=80" alt="" loading="lazy" /></div>
      <div class="insta-img"><img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&q=80" alt="" loading="lazy" /></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Begin your journey</h2>
    <p>Let us help you find the perfect Croatian retreat.</p>
    <a href="/croatia-rentals/contact/" class="btn btn--fill">Get in Touch</a>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    padding-top: 80px;
  }
  
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 10%;
  }
  
  .hero__content h1 {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.1;
    margin: 24px 0;
  }
  
  .hero__content p {
    font-size: 16px;
    color: var(--gray);
    max-width: 400px;
    margin-bottom: 48px;
    line-height: 1.8;
  }
  
  .hero__image {
    overflow: hidden;
  }
  
  .hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  /* Intro */
  .intro {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 60px;
    padding: 160px 10%;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .intro__number {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--gold);
    padding-top: 8px;
  }
  
  .intro__content h2 {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 24px;
    line-height: 1.3;
  }
  
  .intro__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    max-width: 600px;
    margin-bottom: 24px;
  }
  
  .link {
    font-size: 14px;
    color: var(--black);
    transition: color 0.3s;
  }
  
  .link:hover {
    color: var(--gold);
  }
  
  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--light);
    border-bottom: 1px solid var(--light);
  }
  
  .stat {
    padding: 60px 40px;
    text-align: center;
    border-right: 1px solid var(--light);
  }
  
  .stat:last-child {
    border-right: none;
  }
  
  .stat__number {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    margin-bottom: 8px;
  }
  
  .stat__label {
    font-size: 13px;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  /* Villas */
  .villas {
    padding: 120px 5%;
    background: var(--light);
  }
  
  .villas__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
    padding: 0 5%;
  }
  
  .villas__header h2 {
    font-size: 28px;
    flex: 1;
  }
  
  .villas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    padding: 0 5%;
  }
  
  .villa-card {
    display: block;
  }
  
  .villa-card__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    margin-bottom: 20px;
  }
  
  .villa-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .villa-card:hover .villa-card__image img {
    transform: scale(1.05);
  }
  
  .villa-card__info h3 {
    font-size: 22px;
    margin: 8px 0;
  }
  
  .villa-card__price {
    font-size: 13px;
    color: var(--gray);
  }
  
  /* Destinations */
  .destinations {
    padding: 120px 10%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .destinations__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .destinations__header h2 {
    font-size: 28px;
  }
  
  .destinations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  
  .dest-card {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  
  .dest-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .dest-card:hover img {
    transform: scale(1.05);
  }
  
  .dest-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: var(--white);
  }
  
  .dest-card h3 {
    font-size: 24px;
    margin-bottom: 4px;
  }
  
  .dest-card p {
    font-size: 14px;
    opacity: 0.8;
  }
  
  /* Experience */
  .experience {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  
  .experience__image {
    overflow: hidden;
  }
  
  .experience__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .experience__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 10%;
    background: var(--light);
  }
  
  .experience__content h2 {
    font-size: clamp(28px, 4vw, 42px);
    margin: 24px 0;
    line-height: 1.3;
  }
  
  .experience__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    max-width: 500px;
    margin-bottom: 24px;
  }
  
  /* Services */
  .services {
    padding: 120px 10%;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .services__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .services__header h2 {
    font-size: 28px;
  }
  
  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }
  
  .service h4 {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 12px;
  }
  
  .service p {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.7;
  }
  
  /* Testimonials */
  .testimonials {
    padding: 120px 10%;
    background: var(--light);
  }
  
  .testimonials__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .testimonials__header h2 {
    font-size: 28px;
  }
  
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
    max-width: 1000px;
  }
  
  .testimonial {
    padding: 40px;
    background: var(--white);
    border-left: 3px solid var(--gold);
  }
  
  .testimonial p {
    font-size: 18px;
    font-style: italic;
    line-height: 1.8;
    margin-bottom: 24px;
  }
  
  .testimonial__author strong {
    display: block;
    font-weight: 500;
  }
  
  .testimonial__author span {
    font-size: 13px;
    color: var(--gray);
  }
  
  /* Instagram */
  .instagram {
    padding: 120px 5%;
  }
  
  .instagram__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
    padding: 0 5%;
  }
  
  .instagram__header h2 {
    font-size: 28px;
    flex: 1;
  }
  
  .instagram__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  
  .insta-img {
    aspect-ratio: 1;
    overflow: hidden;
  }
  
  .insta-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .insta-img:hover img {
    transform: scale(1.1);
  }
  
  /* CTA */
  .cta {
    text-align: center;
    padding: 160px 5%;
    background: var(--light);
  }
  
  .cta h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 16px;
  }
  
  .cta p {
    font-size: 16px;
    color: var(--gray);
    margin-bottom: 40px;
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero__content { padding: 120px 5% 60px; }
    .hero__image { height: 60vh; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat { border-bottom: 1px solid var(--light); }
    .villas__grid { grid-template-columns: 1fr; gap: 48px; }
    .destinations__grid { grid-template-columns: 1fr; }
    .experience { grid-template-columns: 1fr; }
    .experience__image { height: 50vh; }
    .services__grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials__grid { grid-template-columns: 1fr; }
    .instagram__grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media (max-width: 768px) {
    .intro { grid-template-columns: 1fr; gap: 24px; padding: 80px 5%; }
    .services { padding: 80px 5%; }
    .services__grid { grid-template-columns: 1fr; }
    .stats { grid-template-columns: 1fr; }
    .stat { border-right: none; }
  }
</style>
