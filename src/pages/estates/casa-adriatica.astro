---
import Layout from '../../layouts/Layout.astro';

const estate = {
  name: 'Casa Adriatica',
  location: 'Split · Diocletian Palace',
  tag: 'Waterfront Penthouse',
  price: 650,
  beds: 3,
  baths: 2,
  size: 185,
  guests: 6,
  features: ['Rooftop Terrace', 'Sea View', 'Historic Building', 'City Center'],
  description: `Casa Adriatica occupies the entire top floor of a beautifully restored 18th-century palace, just steps from Diocletian's Palace—one of the best-preserved Roman structures in the world.

The penthouse combines contemporary Scandinavian design with original architectural details, including exposed stone walls and restored wooden beams. Floor-to-ceiling windows flood the space with Mediterranean light.

The crowning glory is the private rooftop terrace, offering 360-degree views of Split's historic center, the harbor, and the islands beyond. Perfect for sunset aperitivos.`,
  amenities: [
    'Private rooftop terrace',
    'Fully equipped designer kitchen',
    'Air conditioning throughout',
    'High-speed WiFi',
    'Smart TV in all rooms',
    'Nespresso machine',
    'Outdoor dining area',
    'Sun loungers',
    'BBQ facilities',
    'Secure building entry',
    'Weekly housekeeping',
    '24/7 concierge service'
  ],
  images: [
    'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=90&auto=format',
    'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85&auto=format'
  ]
};
---

<Layout title={estate.name} description={`${estate.name} - Luxury villa rental in ${estate.location}`}>
  <!-- Hero Gallery -->
  <section class="estate-hero">
    <div class="estate-hero__main">
      <img src={estate.images[0]} alt={estate.name} />
    </div>
    <div class="estate-hero__grid">
      <div class="estate-hero__item">
        <img src={estate.images[1]} alt={`${estate.name} interior`} loading="lazy" />
      </div>
      <div class="estate-hero__item">
        <img src={estate.images[2]} alt={`${estate.name} view`} loading="lazy" />
      </div>
      <div class="estate-hero__item">
        <img src={estate.images[3]} alt={`${estate.name} bedroom`} loading="lazy" />
      </div>
      <div class="estate-hero__item estate-hero__item--more">
        <img src={estate.images[4]} alt={`${estate.name} exterior`} loading="lazy" />
        <div class="estate-hero__more">
          <span>+12 Photos</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Estate Content -->
  <section class="estate-content">
    <div class="estate-main">
      <div class="estate-header">
        <span class="estate-tag">{estate.tag}</span>
        <h1 class="estate-title">{estate.name}</h1>
        <p class="estate-location">{estate.location}</p>
      </div>

      <div class="estate-specs">
        <div class="estate-spec">
          <span class="estate-spec__value">{estate.beds}</span>
          <span class="estate-spec__label">Bedrooms</span>
        </div>
        <div class="estate-spec">
          <span class="estate-spec__value">{estate.baths}</span>
          <span class="estate-spec__label">Bathrooms</span>
        </div>
        <div class="estate-spec">
          <span class="estate-spec__value">{estate.size}m²</span>
          <span class="estate-spec__label">Living Space</span>
        </div>
        <div class="estate-spec">
          <span class="estate-spec__value">{estate.guests}</span>
          <span class="estate-spec__label">Max Guests</span>
        </div>
      </div>

      <div class="estate-features">
        {estate.features.map(feature => (
          <span class="estate-feature">{feature}</span>
        ))}
      </div>

      <div class="estate-description">
        <h2>About This Estate</h2>
        {estate.description.split('\n\n').map(para => (
          <p>{para}</p>
        ))}
      </div>

      <div class="estate-amenities">
        <h2>Amenities</h2>
        <ul class="amenities-grid">
          {estate.amenities.map(amenity => (
            <li>{amenity}</li>
          ))}
        </ul>
      </div>

      <div class="estate-location-section">
        <h2>Location</h2>
        <p>
          Casa Adriatica sits in the very heart of Split, within the ancient walls of 
          Diocletian's Palace. Step outside to explore Roman ruins, bustling markets, 
          and some of Croatia's finest restaurants—all within a 5-minute walk.
        </p>
        <div class="location-highlights">
          <div class="location-item">
            <span class="location-distance">1 min</span>
            <span class="location-name">Diocletian's Palace</span>
          </div>
          <div class="location-item">
            <span class="location-distance">3 min</span>
            <span class="location-name">Riva Promenade</span>
          </div>
          <div class="location-item">
            <span class="location-distance">15 min</span>
            <span class="location-name">Bacvice Beach</span>
          </div>
          <div class="location-item">
            <span class="location-distance">30 min</span>
            <span class="location-name">Split Airport</span>
          </div>
        </div>
      </div>
    </div>

    <aside class="estate-sidebar">
      <div class="booking-card">
        <div class="booking-card__price">
          <span class="price-amount">€{estate.price}</span>
          <span class="price-period">/ night</span>
        </div>
        <div class="booking-card__dates">
          <div class="date-input">
            <label>Check-in</label>
            <input type="date" />
          </div>
          <div class="date-input">
            <label>Check-out</label>
            <input type="date" />
          </div>
        </div>
        <div class="booking-card__guests">
          <label>Guests</label>
          <select>
            <option>2 guests</option>
            <option>4 guests</option>
            <option>6 guests</option>
            <option>8 guests</option>
          </select>
        </div>
        <button class="btn btn--primary btn--full">Request Booking</button>
        <p class="booking-card__note">No payment required yet. Our team will confirm availability.</p>
      </div>

      <div class="contact-card">
        <h4>Questions?</h4>
        <p>Our specialists are available to help with any questions about this property.</p>
        <a href="/contact" class="btn btn--outline btn--full">Contact Us</a>
      </div>
    </aside>
  </section>

  <!-- Related -->
  <section class="related">
    <div class="related__header">
      <h2>Similar Estates</h2>
      <a href="/estates">View All →</a>
    </div>
    <div class="related__grid">
      <a href="/estates/villa-pietra" class="related-card">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=85&auto=format" alt="Villa Pietra" loading="lazy" />
        <div class="related-card__content">
          <span class="related-card__location">Dubrovnik</span>
          <h3>Villa Pietra</h3>
          <span class="related-card__price">From €890/night</span>
        </div>
      </a>
      <a href="/estates/villa-lavanda" class="related-card">
        <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=85&auto=format" alt="Villa Lavanda" loading="lazy" />
        <div class="related-card__content">
          <span class="related-card__location">Hvar</span>
          <h3>Villa Lavanda</h3>
          <span class="related-card__price">From €1,450/night</span>
        </div>
      </a>
    </div>
  </section>
</Layout>

<style>
  .estate-hero {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 8px;
    padding-top: 80px;
    height: 70vh;
    min-height: 500px;
  }
  
  .estate-hero__main {
    overflow: hidden;
  }
  
  .estate-hero__main img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  
  .estate-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 8px;
  }
  
  .estate-hero__item {
    overflow: hidden;
    position: relative;
  }
  
  .estate-hero__item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .estate-hero__item:hover img {
    transform: scale(1.05);
  }
  
  .estate-hero__item--more .estate-hero__more {
    position: absolute;
    inset: 0;
    background: rgba(31, 31, 31, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  
  .estate-hero__item--more:hover .estate-hero__more {
    background: rgba(31, 31, 31, 0.4);
  }
  
  .estate-content {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    padding: 80px 5%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .estate-tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 12px;
    display: block;
  }
  
  .estate-title {
    font-size: clamp(36px, 5vw, 52px);
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  
  .estate-location {
    font-size: 18px;
    color: var(--olive);
    margin-bottom: 40px;
  }
  
  .estate-specs {
    display: flex;
    gap: 40px;
    padding: 32px 0;
    border-top: 1px solid rgba(0,0,0,0.1);
    border-bottom: 1px solid rgba(0,0,0,0.1);
    margin-bottom: 40px;
  }
  
  .estate-spec {
    text-align: center;
  }
  
  .estate-spec__value {
    display: block;
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    color: var(--charcoal);
  }
  
  .estate-spec__label {
    font-size: 13px;
    color: var(--stone);
    margin-top: 4px;
  }
  
  .estate-features {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 48px;
  }
  
  .estate-feature {
    padding: 10px 20px;
    background: var(--linen);
    font-size: 14px;
    color: var(--charcoal);
  }
  
  .estate-description {
    margin-bottom: 48px;
  }
  
  .estate-description h2,
  .estate-amenities h2,
  .estate-location-section h2 {
    font-size: 24px;
    color: var(--charcoal);
    margin-bottom: 20px;
  }
  
  .estate-description p {
    font-size: 16px;
    color: var(--charcoal-light);
    line-height: 1.8;
    margin-bottom: 16px;
  }
  
  .estate-amenities {
    margin-bottom: 48px;
  }
  
  .amenities-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  
  .amenities-grid li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--charcoal);
  }
  
  .amenities-grid li::before {
    content: '✓';
    color: var(--olive);
    font-weight: 600;
  }
  
  .estate-location-section p {
    font-size: 16px;
    color: var(--charcoal-light);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  
  .location-highlights {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  
  .location-item {
    text-align: center;
    padding: 20px;
    background: var(--linen);
  }
  
  .location-distance {
    display: block;
    font-family: 'Instrument Serif', serif;
    font-size: 24px;
    color: var(--olive);
    margin-bottom: 4px;
  }
  
  .location-name {
    font-size: 13px;
    color: var(--charcoal-light);
  }
  
  /* Sidebar */
  .estate-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }
  
  .booking-card {
    background: var(--white);
    border: 1px solid rgba(0,0,0,0.1);
    padding: 32px;
    margin-bottom: 24px;
  }
  
  .booking-card__price {
    text-align: center;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  
  .price-amount {
    font-family: 'Instrument Serif', serif;
    font-size: 36px;
    color: var(--charcoal);
  }
  
  .price-period {
    font-size: 16px;
    color: var(--stone);
  }
  
  .booking-card__dates {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  
  .date-input label,
  .booking-card__guests label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--charcoal);
    margin-bottom: 8px;
  }
  
  .date-input input,
  .booking-card__guests select {
    width: 100%;
    padding: 14px;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    border: 1px solid rgba(0,0,0,0.15);
    background: var(--cream);
    color: var(--charcoal);
  }
  
  .booking-card__guests {
    margin-bottom: 24px;
  }
  
  .btn--full {
    width: 100%;
    justify-content: center;
  }
  
  .booking-card__note {
    font-size: 13px;
    color: var(--stone);
    text-align: center;
    margin-top: 16px;
  }
  
  .contact-card {
    background: var(--linen);
    padding: 24px;
    text-align: center;
  }
  
  .contact-card h4 {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
    color: var(--charcoal);
  }
  
  .contact-card p {
    font-size: 14px;
    color: var(--charcoal-light);
    margin-bottom: 16px;
  }
  
  /* Related */
  .related {
    padding: 80px 5%;
    background: var(--linen);
  }
  
  .related__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }
  
  .related__header h2 {
    font-size: 28px;
    color: var(--charcoal);
  }
  
  .related__header a {
    font-size: 14px;
    font-weight: 500;
    color: var(--olive);
  }
  
  .related__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  
  .related-card {
    display: block;
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  
  .related-card img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .related-card:hover img {
    transform: scale(1.05);
  }
  
  .related-card__content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px;
    background: linear-gradient(to top, rgba(31,31,31,0.9), transparent);
    color: var(--white);
  }
  
  .related-card__location {
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sand);
  }
  
  .related-card__content h3 {
    font-size: 22px;
    margin: 8px 0;
  }
  
  .related-card__price {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
  }
  
  @media (max-width: 1024px) {
    .estate-hero {
      grid-template-columns: 1fr;
      height: auto;
    }
    
    .estate-hero__main {
      aspect-ratio: 16/9;
    }
    
    .estate-hero__grid {
      display: none;
    }
    
    .estate-content {
      grid-template-columns: 1fr;
    }
    
    .estate-sidebar {
      position: static;
    }
    
    .location-highlights {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .estate-hero {
      padding-top: 70px;
    }
    
    .estate-content {
      padding: 40px 5%;
    }
    
    .estate-specs {
      flex-wrap: wrap;
      gap: 24px;
    }
    
    .estate-spec {
      flex: 1 1 40%;
    }
    
    .amenities-grid {
      grid-template-columns: 1fr;
    }
    
    .related__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
