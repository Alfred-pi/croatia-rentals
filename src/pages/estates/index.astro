---
import Layout from '../../layouts/Layout.astro';

const estates = [
  {
    slug: 'villa-pietra',
    name: 'Villa Pietra',
    location: 'Dubrovnik · Old Town',
    tag: 'Signature',
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85&auto=format',
    beds: 4,
    size: 280,
    feature: 'Sea View',
    price: 890,
    desc: 'Historic stone villa with panoramic views of the ancient city walls and crystal-clear Adriatic waters.'
  },
  {
    slug: 'casa-adriatica',
    name: 'Casa Adriatica',
    location: 'Split · Diocletian',
    tag: 'Waterfront',
    image: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85&auto=format',
    beds: 3,
    size: 185,
    feature: 'Rooftop Terrace',
    price: 650,
    desc: 'Modern penthouse in a beautifully restored 18th-century palace, steps from UNESCO heritage sites.'
  },
  {
    slug: 'villa-lavanda',
    name: 'Villa Lavanda',
    location: 'Hvar · Lavender Bay',
    tag: 'Island',
    image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=85&auto=format',
    beds: 5,
    size: 420,
    feature: 'Infinity Pool',
    price: 1450,
    desc: 'Secluded estate surrounded by lavender fields with private infinity pool and yacht mooring.'
  },
  {
    slug: 'korcula-retreat',
    name: 'Korčula Retreat',
    location: 'Korčula · West Coast',
    tag: 'Secluded',
    image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=85&auto=format',
    beds: 6,
    size: 520,
    feature: 'Private Beach',
    price: 2100,
    desc: 'Exclusive beachfront estate with private cove, helipad, and panoramic Adriatic views.'
  },
  {
    slug: 'villa-oliva',
    name: 'Villa Oliva',
    location: 'Istria · Rovinj',
    tag: 'Countryside',
    image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format',
    beds: 4,
    size: 340,
    feature: 'Vineyard',
    price: 780,
    desc: 'Rustic luxury amid olive groves and vineyards, with on-site wine cellar and truffle hunting.'
  },
  {
    slug: 'palace-zadar',
    name: 'Palace Zadar',
    location: 'Zadar · Peninsula',
    tag: 'Heritage',
    image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85&auto=format',
    beds: 5,
    size: 380,
    feature: 'Historic',
    price: 950,
    desc: 'Restored medieval palace with contemporary interiors and views of the famous Sea Organ.'
  }
];
---

<Layout title="All Estates" description="Browse our curated collection of luxury Croatian villas and estates">
  <header class="page-header">
    <span class="page-header__tag">The Collection</span>
    <h1 class="page-header__title">Our Estates</h1>
    <p class="page-header__desc">
      Each property in our portfolio has been personally selected for its exceptional 
      character, breathtaking setting, and the promise of unforgettable moments.
    </p>
  </header>
  
  <section class="estates-page">
    <div class="estates-page__filters">
      <button class="filter active">All</button>
      <button class="filter">Dubrovnik</button>
      <button class="filter">Split</button>
      <button class="filter">Hvar</button>
      <button class="filter">Korčula</button>
      <button class="filter">Istria</button>
    </div>
    
    <div class="estates-page__grid">
      {estates.map(estate => (
        <article class="property-card">
          <a href={`/estates/${estate.slug}`}>
            <div class="property-card__image">
              <img src={estate.image} alt={estate.name} loading="lazy" />
              <span class="property-card__tag">{estate.tag}</span>
            </div>
            <div class="property-card__content">
              <span class="property-card__location">{estate.location}</span>
              <h3 class="property-card__title">{estate.name}</h3>
              <p class="property-card__desc">{estate.desc}</p>
              <div class="property-card__details">
                <span>{estate.beds} Suites</span>
                <span>{estate.size} m²</span>
                <span>{estate.feature}</span>
              </div>
              <div class="property-card__footer">
                <span class="property-card__price">From €{estate.price.toLocaleString()}<small>/night</small></span>
                <span class="property-card__link">View Details →</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .estates-page {
    padding: 80px 5% 140px;
    background: var(--cream);
  }
  
  .estates-page__filters {
    display: flex;
    gap: 12px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }
  
  .filter {
    padding: 12px 24px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    border: 1.5px solid var(--charcoal);
    color: var(--charcoal);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .filter:hover,
  .filter.active {
    background: var(--charcoal);
    color: var(--cream);
  }
  
  .estates-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  
  .property-card {
    background: var(--white);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .property-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.08);
  }
  
  .property-card a {
    display: block;
  }
  
  .property-card__image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .property-card__image img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .property-card:hover .property-card__image img {
    transform: scale(1.05);
  }
  
  .property-card__tag {
    position: absolute;
    top: 16px; left: 16px;
    padding: 8px 16px;
    background: var(--terracotta);
    color: var(--white);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  
  .property-card__content {
    padding: 28px;
  }
  
  .property-card__location {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 8px;
    display: block;
  }
  
  .property-card__title {
    font-family: 'Instrument Serif', serif;
    font-size: 24px;
    color: var(--charcoal);
    margin-bottom: 12px;
  }
  
  .property-card__desc {
    font-size: 15px;
    color: var(--charcoal-light);
    margin-bottom: 16px;
    line-height: 1.6;
  }
  
  .property-card__details {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: var(--stone);
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  
  .property-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .property-card__price {
    font-family: 'Instrument Serif', serif;
    font-size: 22px;
    color: var(--charcoal);
  }
  
  .property-card__price small {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: var(--stone);
  }
  
  .property-card__link {
    font-size: 13px;
    font-weight: 500;
    color: var(--olive);
    transition: color 0.3s ease;
  }
  
  .property-card:hover .property-card__link {
    color: var(--charcoal);
  }
  
  @media (max-width: 1024px) {
    .estates-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .estates-page {
      padding: 60px 5% 100px;
    }
    
    .estates-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
