---
import Layout from '../../layouts/Layout.astro';

const villas = [
  { name: 'Villa Pietra', location: 'Dubrovnik', beds: 4, price: 890, image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=85', slug: 'villa-pietra' },
  { name: 'Casa Blu', location: 'Hvar', beds: 5, price: 1200, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85', slug: 'casa-blu' },
  { name: 'Villa Oliva', location: 'Split', beds: 3, price: 750, image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85', slug: 'villa-oliva' },
  { name: 'Villa Tramonto', location: 'Korčula', beds: 4, price: 950, image: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85', slug: 'villa-tramonto' },
  { name: 'Casa Mediterra', location: 'Rovinj', beds: 6, price: 1450, image: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85', slug: 'casa-mediterra' },
  { name: 'Villa Mare', location: 'Zadar', beds: 3, price: 680, image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=85', slug: 'villa-mare' },
];
---

<Layout title="Villas — ADRIATIC">
  <section class="page-header">
    <span class="tag">Collection</span>
    <h1>Our Villas</h1>
    <p>Six exceptional properties along Croatia's Adriatic coast.</p>
  </section>

  <section class="villas-list">
    {villas.map((villa, i) => (
      <a href={`/croatia-rentals/villas/${villa.slug}/`} class="villa-row">
        <div class="villa-row__image">
          <img src={villa.image} alt={villa.name} loading="lazy" />
        </div>
        <div class="villa-row__content">
          <span class="villa-row__number">0{i + 1}</span>
          <div class="villa-row__info">
            <span class="tag">{villa.location}</span>
            <h2>{villa.name}</h2>
            <div class="villa-row__details">
              <span>{villa.beds} bedrooms</span>
              <span>From €{villa.price}/night</span>
            </div>
          </div>
          <span class="villa-row__arrow">→</span>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .page-header {
    padding: 180px 5% 100px;
    text-align: center;
  }
  
  .page-header h1 {
    font-size: clamp(40px, 6vw, 64px);
    margin: 16px 0;
  }
  
  .page-header p {
    font-size: 16px;
    color: var(--gray);
  }
  
  .villas-list {
    padding: 0 5% 100px;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .villa-row {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 60px;
    align-items: center;
    padding: 60px 0;
    border-bottom: 1px solid var(--light);
  }
  
  .villa-row:first-child {
    border-top: 1px solid var(--light);
  }
  
  .villa-row__image {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .villa-row__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .villa-row:hover .villa-row__image img {
    transform: scale(1.05);
  }
  
  .villa-row__content {
    display: flex;
    align-items: center;
    gap: 48px;
  }
  
  .villa-row__number {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--gold);
  }
  
  .villa-row__info {
    flex: 1;
  }
  
  .villa-row__info h2 {
    font-size: 32px;
    margin: 8px 0 16px;
    transition: color 0.3s;
  }
  
  .villa-row:hover .villa-row__info h2 {
    color: var(--gold);
  }
  
  .villa-row__details {
    display: flex;
    gap: 32px;
    font-size: 14px;
    color: var(--gray);
  }
  
  .villa-row__arrow {
    font-size: 24px;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s;
  }
  
  .villa-row:hover .villa-row__arrow {
    opacity: 1;
    transform: translateX(0);
  }
  
  @media (max-width: 900px) {
    .villa-row {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .villa-row__content { gap: 24px; }
    .villa-row__arrow { display: none; }
  }
</style>
