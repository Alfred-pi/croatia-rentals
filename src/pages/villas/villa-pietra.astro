---
import Layout from '../../layouts/Layout.astro';

const villa = {
  name: 'Villa Pietra',
  location: 'Dubrovnik',
  price: 890,
  beds: 4,
  baths: 3,
  guests: 8,
  size: 280,
  images: [
    'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1400&q=90&auto=format',
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85&auto=format',
  ]
};
---

<Layout title={`${villa.name} — ADRIATIC`}>
  <section class="villa-hero">
    <img src={villa.images[0]} alt={villa.name} />
    <div class="villa-hero__overlay"></div>
    <div class="villa-hero__content">
      <span>{villa.location}</span>
      <h1>{villa.name}</h1>
    </div>
  </section>

  <section class="villa-intro">
    <div class="villa-intro__main">
      <p class="lead">A meticulously restored 16th-century stone residence perched above Dubrovnik's Old Town, blending centuries of history with contemporary luxury.</p>
      <p>The villa offers panoramic views of the Adriatic Sea and the iconic terracotta rooftops of the Old Town. Each of the four suites has been individually designed, featuring original stone walls, hand-crafted furniture, and modern amenities.</p>
    </div>
    <div class="villa-intro__specs">
      <div class="spec">
        <span class="spec__value">{villa.beds}</span>
        <span class="spec__label">Bedrooms</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.baths}</span>
        <span class="spec__label">Bathrooms</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.guests}</span>
        <span class="spec__label">Guests</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.size}m²</span>
        <span class="spec__label">Space</span>
      </div>
    </div>
  </section>

  <section class="villa-gallery">
    {villa.images.slice(1).map(img => (
      <div class="gallery-item">
        <img src={img} alt={villa.name} loading="lazy" />
      </div>
    ))}
  </section>

  <section class="villa-features">
    <div class="features-col">
      <h3>The Space</h3>
      <p>Four individually designed suites feature original stone walls, hand-crafted furniture, and modern amenities. The private infinity pool appears to merge with the sea beyond.</p>
    </div>
    <div class="features-col">
      <h3>Amenities</h3>
      <ul>
        <li>Private infinity pool</li>
        <li>Sea view terraces</li>
        <li>Gourmet kitchen</li>
        <li>Wine cellar</li>
        <li>Daily housekeeping</li>
        <li>24/7 concierge</li>
      </ul>
    </div>
    <div class="features-col">
      <h3>Location</h3>
      <ul>
        <li>2 min to Old Town</li>
        <li>5 min to City Walls</li>
        <li>10 min to Beach</li>
        <li>25 min to Airport</li>
      </ul>
    </div>
  </section>

  <section class="villa-booking">
    <div class="booking-card">
      <div class="booking-price">
        <span class="price">€{villa.price}</span>
        <span class="period">per night</span>
      </div>
      <p>Minimum 3 nights · Includes housekeeping</p>
      <a href="/croatia-rentals/contact/" class="btn btn--primary">Request This Villa</a>
    </div>
  </section>

  <section class="villa-nav">
    <a href="/croatia-rentals/villas/">← All Villas</a>
    <a href="/croatia-rentals/villas/casa-blu/">Next: Casa Blu →</a>
  </section>
</Layout>

<style>
  .villa-hero {
    position: relative;
    height: 70vh;
    min-height: 500px;
  }
  
  .villa-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .villa-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,20,25,0.7), transparent 50%);
  }
  
  .villa-hero__content {
    position: absolute;
    bottom: 60px;
    left: 5%;
    color: var(--white);
  }
  
  .villa-hero__content span {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 12px;
    padding: 8px 16px;
    border: 1px solid var(--coral);
    border-radius: 20px;
  }
  
  .villa-hero__content h1 {
    font-size: clamp(40px, 6vw, 64px);
  }
  
  .villa-intro {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 60px;
    padding: 80px 5%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .villa-intro__main .lead {
    font-size: 22px;
    line-height: 1.6;
    color: var(--black);
    margin-bottom: 20px;
  }
  
  .villa-intro__main p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
  }
  
  .villa-intro__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  
  .spec {
    background: var(--light);
    padding: 24px;
    text-align: center;
    border-radius: 8px;
  }
  
  .spec__value {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    color: var(--blue);
    margin-bottom: 4px;
  }
  
  .spec__label {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
  }
  
  .villa-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 0 5%;
  }
  
  .gallery-item {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 8px;
  }
  
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  
  .gallery-item:hover img {
    transform: scale(1.05);
  }
  
  .villa-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
    padding: 80px 5%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .features-col h3 {
    font-size: 22px;
    margin-bottom: 20px;
    color: var(--black);
  }
  
  .features-col p {
    font-size: 15px;
    color: var(--gray);
    line-height: 1.8;
  }
  
  .features-col ul {
    list-style: none;
  }
  
  .features-col li {
    padding: 12px 0;
    border-bottom: 1px solid var(--light);
    font-size: 15px;
    color: var(--gray);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .features-col li::before {
    content: '✓';
    color: var(--coral);
    font-weight: bold;
  }
  
  .villa-booking {
    background: var(--blue);
    padding: 60px 5%;
    display: flex;
    justify-content: center;
  }
  
  .booking-card {
    background: var(--white);
    padding: 48px;
    border-radius: 12px;
    text-align: center;
    max-width: 400px;
    width: 100%;
  }
  
  .booking-price {
    margin-bottom: 16px;
  }
  
  .price {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    color: var(--blue);
  }
  
  .period {
    display: block;
    font-size: 14px;
    color: var(--gray);
  }
  
  .booking-card > p {
    font-size: 14px;
    color: var(--gray);
    margin-bottom: 24px;
  }
  
  .booking-card .btn {
    width: 100%;
  }
  
  .villa-nav {
    display: flex;
    justify-content: space-between;
    padding: 32px 5%;
    border-top: 1px solid var(--light);
  }
  
  .villa-nav a {
    font-size: 14px;
    color: var(--gray);
    transition: color 0.3s;
  }
  
  .villa-nav a:hover {
    color: var(--coral);
  }
  
  @media (max-width: 900px) {
    .villa-intro {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .villa-intro__specs {
      grid-template-columns: repeat(4, 1fr);
    }
    
    .villa-gallery {
      grid-template-columns: 1fr;
    }
    
    .villa-features {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  
  @media (max-width: 600px) {
    .villa-intro__specs {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
