---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const villa = {
  name: 'Villa Pietra',
  location: 'Dubrovnik',
  price: 890,
  beds: 4,
  baths: 3,
  guests: 8,
  size: 280,
  images: [
    'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1400&q=90&auto=format',
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85&auto=format',
    'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=85&auto=format',
  ]
};
---

<Layout title={`${villa.name} — ADRIATIC`}>
  <section class="villa-hero">
    <img src={villa.images[0]} alt={villa.name} />
  </section>

  <section class="villa-intro">
    <div class="villa-intro__main">
      <span class="villa-intro__location">{villa.location}</span>
      <h1>{villa.name}</h1>
      <p>A meticulously restored 16th-century stone residence perched above Dubrovnik's Old Town, blending centuries of history with contemporary luxury.</p>
    </div>
    <div class="villa-intro__specs">
      <div class="spec">
        <span class="spec__value">{villa.beds}</span>
        <span class="spec__label">Bedrooms</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.baths}</span>
        <span class="spec__label">Bathrooms</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.guests}</span>
        <span class="spec__label">Guests</span>
      </div>
      <div class="spec">
        <span class="spec__value">{villa.size}m²</span>
        <span class="spec__label">Space</span>
      </div>
    </div>
  </section>

  <section class="villa-gallery">
    {villa.images.slice(1).map(img => (
      <div class="gallery-item">
        <img src={img} alt={villa.name} loading="lazy" />
      </div>
    ))}
  </section>

  <section class="villa-details">
    <div class="details-col">
      <h3>The Space</h3>
      <p>Four individually designed suites feature original stone walls, hand-crafted furniture, and modern amenities. The private infinity pool appears to merge with the sea beyond.</p>
    </div>
    <div class="details-col">
      <h3>Amenities</h3>
      <ul>
        <li>Private infinity pool</li>
        <li>Sea view terraces</li>
        <li>Gourmet kitchen</li>
        <li>Wine cellar</li>
        <li>Daily housekeeping</li>
        <li>24/7 concierge</li>
      </ul>
    </div>
  </section>

  <section class="villa-booking">
    <div class="booking-price">
      <span class="price">€{villa.price}</span>
      <span class="period">per night</span>
    </div>
    <a href={`${base}contact/`} class="btn btn--fill">Request This Villa</a>
  </section>

  <section class="villa-nav">
    <a href={`${base}villas/`}>← All Villas</a>
    <a href={`${base}villas/casa-blu/`}>Next: Casa Blu →</a>
  </section>
</Layout>

<style>
  .villa-hero {
    padding-top: 72px;
    height: 85vh;
    overflow: hidden;
  }
  
  .villa-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .villa-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 100px 10%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .villa-intro__location {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 16px;
  }
  
  .villa-intro__main h1 {
    font-size: clamp(36px, 5vw, 52px);
    margin-bottom: 24px;
  }
  
  .villa-intro__main p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
  }
  
  .villa-intro__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-content: center;
  }
  
  .spec {
    text-align: center;
    padding: 32px;
    border: 1px solid var(--light);
  }
  
  .spec__value {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    margin-bottom: 8px;
  }
  
  .spec__label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
  }
  
  .villa-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 0 5%;
  }
  
  .gallery-item {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .gallery-item:hover img {
    transform: scale(1.05);
  }
  
  .villa-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 100px 10%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .details-col h3 {
    font-size: 24px;
    margin-bottom: 24px;
  }
  
  .details-col p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
  }
  
  .details-col ul {
    list-style: none;
  }
  
  .details-col li {
    padding: 12px 0;
    border-bottom: 1px solid var(--light);
    font-size: 15px;
    color: var(--gray);
  }
  
  .details-col li:first-child {
    border-top: 1px solid var(--light);
  }
  
  .villa-booking {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 60px;
    padding: 80px 5%;
    background: var(--light);
  }
  
  .booking-price {
    text-align: right;
  }
  
  .price {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
  }
  
  .period {
    display: block;
    font-size: 14px;
    color: var(--gray);
  }
  
  .villa-nav {
    display: flex;
    justify-content: space-between;
    padding: 40px 5%;
    border-top: 1px solid var(--light);
  }
  
  .villa-nav a {
    font-size: 14px;
    color: var(--gray);
    transition: color 0.3s;
  }
  
  .villa-nav a:hover {
    color: var(--black);
  }
  
  @media (max-width: 900px) {
    .villa-intro,
    .villa-details {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 60px 5%;
    }
    
    .villa-gallery {
      grid-template-columns: 1fr;
    }
    
    .villa-booking {
      flex-direction: column;
      gap: 32px;
    }
    
    .booking-price {
      text-align: center;
    }
  }
</style>
