---
import Layout from '../../layouts/Layout.astro';

const villa = {
  name: 'Villa Mare',
  location: 'Brač',
  price: 1450,
  beds: 4,
  baths: 3,
  guests: 8,
  size: 280,
  images: [
    'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1200&q=85',
    'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=85',
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=85',
    'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=600&q=85',
    'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=600&q=85',
  ],
  features: ['Sea View', 'Private Pool', 'Historic Stone', 'Wine Cellar', 'Garden'],
  amenities: ['Heated infinity pool', 'Air conditioning', 'Fully equipped kitchen', 'High-speed WiFi', 'Smart home system', 'Private parking', 'Outdoor dining area', 'BBQ & pizza oven', 'Laundry facilities', 'Daily housekeeping', 'Concierge service', 'Private chef available'],
};

const related = [
  { name: 'Casa Blu', location: 'Hvar', price: 1200, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=85', slug: 'casa-blu' },
  { name: 'Villa Oliva', location: 'Split', price: 750, image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=85', slug: 'villa-oliva' },
];
---

<Layout title={`${villa.name} — ADRIATIC`}>
  <!-- Hero Gallery -->
  <section class="gallery">
    <div class="gallery__main">
      <img src={villa.images[0]} alt={villa.name} />
    </div>
    <div class="gallery__grid">
      {villa.images.slice(1).map(img => (
        <div class="gallery__item">
          <img src={img} alt={villa.name} loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- Header -->
  <section class="header reveal">
    <div class="header__content">
      <span class="tag">{villa.location}, Croatia</span>
      <h1>{villa.name}</h1>
      <div class="line"></div>
      <div class="header__specs">
        <span>{villa.beds} bedrooms</span>
        <span class="dot"></span>
        <span>{villa.baths} bathrooms</span>
        <span class="dot"></span>
        <span>{villa.guests} guests</span>
        <span class="dot"></span>
        <span>{villa.size}m²</span>
      </div>
    </div>
    <div class="header__booking">
      <div class="booking-card">
        <div class="booking-card__price">
          <span class="price">€{villa.price}</span>
          <span class="unit">/ night</span>
        </div>
        <div class="booking-card__dates">
          <div class="booking-card__field">
            <label>Check-in</label>
            <input type="date" />
          </div>
          <div class="booking-card__field">
            <label>Check-out</label>
            <input type="date" />
          </div>
        </div>
        <div class="booking-card__field">
          <label>Guests</label>
          <select>
            <option>2 guests</option>
            <option>4 guests</option>
            <option>6 guests</option>
            <option>12 guests</option>
          </select>
        </div>
        <a href="/croatia-rentals/contact/" class="btn btn--fill">Request Booking</a>
        <p class="booking-card__note">No payment required. We'll confirm availability.</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features reveal">
    {villa.features.map(feature => (
      <span class="feature">{feature}</span>
    ))}
  </section>

  <!-- Description -->
  <section class="description">
    <div class="description__content reveal">
      <span class="intro__number">01</span>
      <span class="tag">The Property</span>
      <h2>The ultimate retreat<br/>above the <em>Adriatic</em></h2>
      <div class="line"></div>
      <p>Villa Mare is a stunning 19th-century stone house that has been meticulously restored to offer the perfect blend of historic charm and contemporary luxury. Perched on a hillside overlooking the old town of Brač, this exceptional property offers breathtaking panoramic views of the Adriatic Sea and the iconic city walls.</p>
      <p>The villa features four beautifully appointed bedrooms, each with its own ensuite bathroom and spectacular views. The open-plan living area flows seamlessly onto a large terrace where you can enjoy al fresco dining while watching the sunset paint the sky in shades of gold and crimson.</p>
      <p>The heated infinity pool appears to merge with the sea beyond, creating an unforgettable visual experience. Surrounded by Mediterranean gardens of lavender, olive trees, and bougainvillea, Villa Mare is truly a sanctuary of peace and beauty.</p>
    </div>
  </section>

  <!-- Amenities -->
  <section class="amenities reveal">
    <div class="amenities__header">
      <span class="intro__number">02</span>
      <div>
        <span class="tag">What's Included</span>
        <h3>Amenities</h3>
      </div>
    </div>
    <div class="amenities__grid">
      {villa.amenities.map(amenity => (
        <div class="amenity">
          <span class="amenity__check">✓</span>
          <span>{amenity}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Location -->
  <section class="location reveal">
    <div class="location__content">
      <span class="intro__number">03</span>
      <span class="tag">Location</span>
      <h3>{villa.location}, Croatia</h3>
      <div class="line"></div>
      <div class="location__distances">
        <div class="distance">
          <span class="distance__value">5 min</span>
          <span class="distance__label">to Old Town</span>
        </div>
        <div class="distance">
          <span class="distance__value">15 min</span>
          <span class="distance__label">to Airport</span>
        </div>
        <div class="distance">
          <span class="distance__value">2 min</span>
          <span class="distance__label">to Beach</span>
        </div>
        <div class="distance">
          <span class="distance__value">Walking</span>
          <span class="distance__label">to Restaurants</span>
        </div>
      </div>
    </div>
    <div class="location__image">
      <img src="https://images.unsplash.com/photo-1555990538-1e15d5b97d8d?w=800&q=85" alt="Brač" />
    </div>
  </section>

  <!-- Related -->
  <section class="related">
    <div class="related__header reveal">
      <span class="intro__number">04</span>
      <div>
        <span class="tag">More Properties</span>
        <h3>You may also like</h3>
      </div>
      <a href="/croatia-rentals/villas/" class="link">View All →</a>
    </div>
    <div class="related__grid">
      {related.map((v, i) => (
        <a href={`/croatia-rentals/villas/${v.slug}/`} class="related-card reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="related-card__image">
            <img src={v.image} alt={v.name} loading="lazy" />
          </div>
          <div class="related-card__info">
            <span class="tag">{v.location}</span>
            <h4>{v.name}</h4>
            <span class="related-card__price">From €{v.price}/night</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* Gallery */
  .gallery {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 8px;
    padding-top: 80px;
  }
  
  .gallery__main {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  
  .gallery__item {
    aspect-ratio: 1;
    overflow: hidden;
  }
  
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  
  .gallery__item:hover img {
    transform: scale(1.05);
  }
  
  /* Header */
  .header {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    padding: 80px 10%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .header__content h1 {
    font-size: clamp(36px, 5vw, 56px);
    margin: 16px 0 0;
  }
  
  .header__specs {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--gray);
  }
  
  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gray);
    opacity: 0.4;
  }
  
  /* Booking Card */
  .booking-card {
    padding: 40px;
    background: var(--light);
    position: sticky;
    top: 100px;
  }
  
  .booking-card__price {
    margin-bottom: 32px;
  }
  
  .booking-card__price .price {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
  }
  
  .booking-card__price .unit {
    font-size: 14px;
    color: var(--gray);
  }
  
  .booking-card__dates {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  
  .booking-card__field {
    margin-bottom: 16px;
  }
  
  .booking-card__field label {
    display: block;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gray);
    margin-bottom: 8px;
  }
  
  .booking-card__field input,
  .booking-card__field select {
    width: 100%;
    padding: 14px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    border: 1px solid rgba(0,0,0,0.1);
    background: var(--white);
    -webkit-appearance: none;
    border-radius: 0;
  }
  
  .booking-card .btn {
    width: 100%;
    margin-top: 16px;
  }
  
  .booking-card__note {
    font-size: 12px;
    color: var(--gray);
    text-align: center;
    margin-top: 16px;
  }
  
  /* Features */
  .features {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 0 10%;
    max-width: 900px;
  }
  
  .feature {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 12px 24px;
    border: 1px solid rgba(0,0,0,0.1);
    transition: all 0.3s;
  }
  
  .feature:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  
  /* Description */
  .description {
    padding: 120px 10%;
    max-width: 900px;
  }
  
  .intro__number {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    color: var(--gold);
    margin-bottom: 16px;
    display: block;
  }
  
  .description h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    margin: 16px 0 0;
    line-height: 1.2;
  }
  
  .description h2 em {
    font-style: italic;
    color: var(--gold);
  }
  
  .description p {
    font-size: 16px;
    color: var(--gray);
    line-height: 2;
    margin-bottom: 24px;
  }
  
  /* Amenities */
  .amenities {
    padding: 100px 10%;
    background: var(--light);
  }
  
  .amenities__header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .amenities__header h3 {
    font-size: 28px;
    margin-top: 8px;
  }
  
  .amenities__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  
  .amenity {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
  }
  
  .amenity__check {
    color: var(--gold);
  }
  
  /* Location */
  .location {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }
  
  .location__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 10%;
  }
  
  .location__content h3 {
    font-size: 32px;
    margin: 16px 0 0;
  }
  
  .location__distances {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 40px;
  }
  
  .distance__value {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    margin-bottom: 4px;
  }
  
  .distance__label {
    font-size: 13px;
    color: var(--gray);
  }
  
  .location__image {
    overflow: hidden;
  }
  
  .location__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  /* Related */
  .related {
    padding: 120px 10%;
  }
  
  .related__header {
    display: flex;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .related__header > div {
    flex: 1;
  }
  
  .related__header h3 {
    font-size: 28px;
    margin-top: 8px;
  }
  
  .related__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  
  .related-card {
    display: block;
  }
  
  .related-card__image {
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 20px;
  }
  
  .related-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  
  .related-card:hover .related-card__image img {
    transform: scale(1.05);
  }
  
  .related-card__info h4 {
    font-size: 22px;
    margin: 8px 0;
  }
  
  .related-card__price {
    font-size: 14px;
    color: var(--gray);
  }
  
  .link {
    font-size: 13px;
    color: var(--black);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s;
  }
  
  .link:hover {
    color: var(--gold);
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .gallery { grid-template-columns: 1fr; }
    .gallery__main { aspect-ratio: 16/9; }
    .gallery__grid { display: none; }
    .header { grid-template-columns: 1fr; }
    .booking-card { position: static; }
    .amenities__grid { grid-template-columns: repeat(2, 1fr); }
    .location { grid-template-columns: 1fr; }
    .location__image { height: 50vh; }
    .related__grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 768px) {
    .amenities__grid { grid-template-columns: 1fr; }
    .location__distances { grid-template-columns: 1fr; }
    .features { padding: 0 5%; }
  }
</style>
