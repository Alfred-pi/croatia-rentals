---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Villa Tramonto — ADRIATIC">
  <section class="villa-hero">
    <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1400&q=90" alt="Villa Tramonto" />
  </section>

  <section class="villa-intro">
    <div class="villa-intro__main">
      <span class="tag">Korčula</span>
      <h1>Villa Tramonto</h1>
      <p class="lead">Perched on Korčula's western shore, famous for its spectacular sunsets over the Pelješac peninsula.</p>
      <p>Villa Tramonto captures the golden hour light in every room. This contemporary villa features clean lines, natural materials, and an ever-changing canvas of sky and sea.</p>
    </div>
    <div class="villa-intro__specs">
      <div class="spec"><span>4</span>Bedrooms</div>
      <div class="spec"><span>3</span>Bathrooms</div>
      <div class="spec"><span>8</span>Guests</div>
      <div class="spec"><span>260m²</span>Space</div>
    </div>
  </section>

  <section class="villa-gallery">
    <div class="gallery-item"><img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=85" alt="Interior" loading="lazy" /></div>
    <div class="gallery-item"><img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85" alt="View" loading="lazy" /></div>
    <div class="gallery-item"><img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=85" alt="Terrace" loading="lazy" /></div>
  </section>

  <section class="villa-details">
    <div class="details-col">
      <h3>The Space</h3>
      <p>Four bedrooms with sunset views, an open-plan living area, and multiple terraces designed for watching the famous Korčula sunsets.</p>
    </div>
    <div class="details-col">
      <h3>Amenities</h3>
      <ul>
        <li>Infinity pool</li>
        <li>Sunset terraces</li>
        <li>Professional kitchen</li>
        <li>Wine storage</li>
        <li>Daily housekeeping</li>
        <li>Boat rental available</li>
      </ul>
    </div>
    <div class="details-col">
      <h3>Location</h3>
      <ul>
        <li>10 min to Korčula Town</li>
        <li>2 min to beach</li>
        <li>15 min to ferry</li>
        <li>2 hrs to Dubrovnik</li>
      </ul>
    </div>
  </section>

  <section class="villa-booking">
    <div class="booking-price">
      <span class="price">€950</span>
      <span class="period">per night</span>
    </div>
    <a href="/croatia-rentals/contact/" class="btn btn--fill">Request This Villa</a>
  </section>

  <section class="villa-nav">
    <a href="/croatia-rentals/villas/villa-oliva/">← Villa Oliva</a>
    <a href="/croatia-rentals/villas/casa-mediterra/">Next: Casa Mediterra →</a>
  </section>
</Layout>

<style>
  .villa-hero { padding-top: 72px; height: 80vh; overflow: hidden; }
  .villa-hero img { width: 100%; height: 100%; object-fit: cover; }
  .villa-intro { display: grid; grid-template-columns: 1.5fr 1fr; gap: 80px; padding: 100px 10%; max-width: 1400px; margin: 0 auto; }
  .villa-intro__main h1 { font-size: clamp(36px, 5vw, 52px); margin: 12px 0 24px; }
  .villa-intro__main .lead { font-size: 20px; line-height: 1.6; margin-bottom: 16px; }
  .villa-intro__main p { font-size: 16px; color: var(--gray); line-height: 1.9; }
  .villa-intro__specs { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-content: center; }
  .spec { text-align: center; padding: 32px; border: 1px solid var(--light); }
  .spec span { display: block; font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 8px; }
  .villa-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 0 5%; }
  .gallery-item { aspect-ratio: 4/3; overflow: hidden; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .gallery-item:hover img { transform: scale(1.05); }
  .villa-details { display: grid; grid-template-columns: repeat(3, 1fr); gap: 60px; padding: 100px 10%; max-width: 1400px; margin: 0 auto; }
  .details-col h3 { font-size: 20px; margin-bottom: 20px; }
  .details-col p { font-size: 15px; color: var(--gray); line-height: 1.8; }
  .details-col ul { list-style: none; }
  .details-col li { padding: 12px 0; border-bottom: 1px solid var(--light); font-size: 15px; color: var(--gray); }
  .villa-booking { display: flex; align-items: center; justify-content: center; gap: 60px; padding: 80px 5%; background: var(--light); }
  .booking-price { text-align: right; }
  .price { font-family: 'Playfair Display', serif; font-size: 48px; }
  .period { display: block; font-size: 14px; color: var(--gray); }
  .villa-nav { display: flex; justify-content: space-between; padding: 40px 5%; border-top: 1px solid var(--light); }
  .villa-nav a { font-size: 14px; color: var(--gray); transition: color 0.3s; }
  .villa-nav a:hover { color: var(--black); }
  @media (max-width: 900px) {
    .villa-intro, .villa-details { grid-template-columns: 1fr; gap: 48px; padding: 60px 5%; }
    .villa-intro__specs { grid-template-columns: repeat(4, 1fr); }
    .villa-gallery { grid-template-columns: 1fr; }
    .villa-booking { flex-direction: column; gap: 32px; }
    .booking-price { text-align: center; }
  }
  @media (max-width: 600px) { .villa-intro__specs { grid-template-columns: repeat(2, 1fr); } }
</style>
