    gap: 8px;
    transition: color 0.3s;
  }
  
  .link:hover {
    color: var(--gold);
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .gallery { grid-template-columns: 1fr; }
    .gallery__main { aspect-ratio: 16/9; }
    .gallery__grid { display: none; }
    .header { grid-template-columns: 1fr; }
    .booking-card { position: static; }
    .photo-grid__images { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .photo-grid__item--large { grid-column: span 2; grid-row: span 1; }
    .description { grid-template-columns: 1fr; }
    .description__image { height: 50vh; }
    .rooms__grid { grid-template-columns: repeat(2, 1fr); }
    .amenities__grid { grid-template-columns: repeat(2, 1fr); }
    .location { grid-template-columns: 1fr; }
    .location__image { height: 50vh; }
    .related__grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 768px) {
    .photo-grid__images { grid-template-columns: 1fr; }
    .photo-grid__item--large { grid-column: span 1; }
    .rooms__grid { grid-template-columns: 1fr; }
    .amenities__grid { grid-template-columns: 1fr; }
    .location__distances { grid-template-columns: 1fr; }
    .features { padding: 0 5%; }
    .calendar-wrapper { grid-template-columns: 1fr; }
    .availability__legend { display: none; }
    .availability__header { flex-direction: column; }
  }
</style>

<script>
  // Lightbox functionality
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxCounter = document.getElementById('lightbox-counter');
  
  const gallery = [
    { src: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1200&q=85', caption: 'Villa exterior & pool' },
    { src: 'https://images.unsplash.com/photo-1575429198097-0414ec08e8cd?w=1200&q=85', caption: 'Infinity pool with sea view' },
    { src: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1200&q=85', caption: 'Open plan living area' },
    { src: 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1200&q=85', caption: 'Master bedroom' },
    { src: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1200&q=85', caption: 'Guest bedroom' },
    { src: 'https://images.unsplash.com/photo-1600566752355-35792bedcfea?w=1200&q=85', caption: 'Outdoor dining terrace' },
    { src: 'https://images.unsplash.com/photo-1600566752229-250ed79470f8?w=1200&q=85', caption: 'Luxury bathroom' },
    { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=85', caption: 'Gourmet kitchen' },
    { src: 'https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=1200&q=85', caption: 'Sea view from terrace' },
    { src: 'https://images.unsplash.com/photo-1580137189272-c9379f8864fd?w=1200&q=85', caption: 'Korčula Old Town nearby' },
  ];
  
  let currentIndex = 0;
  
  function showImage(index) {
    currentIndex = index;
    lightboxImg.src = gallery[index].src;
    lightboxCaption.textContent = gallery[index].caption;
    lightboxCounter.textContent = `${index + 1} / ${gallery.length}`;
  }
  
  document.getElementById('open-lightbox')?.addEventListener('click', () => {
    lightbox.classList.add('active');
    showImage(0);
    document.body.style.overflow = 'hidden';
  });
  
  document.getElementById('close-lightbox')?.addEventListener('click', () => {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  });
  
  document.getElementById('lightbox-prev')?.addEventListener('click', () => {
    showImage((currentIndex - 1 + gallery.length) % gallery.length);
  });
  
  document.getElementById('lightbox-next')?.addEventListener('click', () => {
    showImage((currentIndex + 1) % gallery.length);
  });
  
  // Photo grid click
  document.querySelectorAll('.photo-grid__item').forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index);
      lightbox.classList.add('active');
      showImage(index);
      document.body.style.overflow = 'hidden';
    });
  });
  
  // Gallery grid click
  document.querySelectorAll('.gallery__item').forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index);
      lightbox.classList.add('active');
      showImage(index);
      document.body.style.overflow = 'hidden';
    });
  });
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    }
    if (e.key === 'ArrowLeft') showImage((currentIndex - 1 + gallery.length) % gallery.length);
    if (e.key === 'ArrowRight') showImage((currentIndex + 1) % gallery.length);
  });

  // Calendar functionality
  const bookedDates = [
    '2026-04-05', '2026-04-06', '2026-04-07', '2026-04-08', '2026-04-09', '2026-04-10', '2026-04-11', '2026-04-12',
    '2026-04-20', '2026-04-21', '2026-04-22', '2026-04-23', '2026-04-24', '2026-04-25', '2026-04-26',
    '2026-05-01', '2026-05-02', '2026-05-03', '2026-05-04', '2026-05-05',
    '2026-05-15', '2026-05-16', '2026-05-17', '2026-05-18', '2026-05-19', '2026-05-20', '2026-05-21',
    '2026-06-10', '2026-06-11', '2026-06-12', '2026-06-13', '2026-06-14', '2026-06-15', '2026-06-16', '2026-06-17', '2026-06-18', '2026-06-19', '2026-06-20',
    '2026-07-01', '2026-07-02', '2026-07-03', '2026-07-04', '2026-07-05', '2026-07-06', '2026-07-07', '2026-07-08', '2026-07-09', '2026-07-10',
    '2026-07-20', '2026-07-21', '2026-07-22', '2026-07-23', '2026-07-24', '2026-07-25', '2026-07-26', '2026-07-27', '2026-07-28', '2026-07-29', '2026-07-30',
    '2026-08-05', '2026-08-06', '2026-08-07', '2026-08-08', '2026-08-09', '2026-08-10', '2026-08-11', '2026-08-12', '2026-08-13', '2026-08-14', '2026-08-15',
  ];

  let currentDate = new Date();
  let selectedStart = null;
  let selectedEnd = null;

  function formatDate(date) {
    return date.toISOString().split('T')[0];
  }

  function isBooked(dateStr) {
    return bookedDates.includes(dateStr);
  }

  function isPast(date) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return date < today;
  }

  function isToday(date) {
    const today = new Date();
    return date.toDateString() === today.toDateString();
  }

  function renderCalendar(calendarNum, year, month) {
    const monthEl = document.getElementById(`month-${calendarNum}`);
    const daysEl = document.getElementById(`days-${calendarNum}`);
    
    if (!monthEl || !daysEl) return;
    
    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                        'July', 'August', 'September', 'October', 'November', 'December'];
    
    monthEl.textContent = `${monthNames[month]} ${year}`;
    
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const startingDay = (firstDay.getDay() + 6) % 7;
    
    let html = '';
    
    for (let i = 0; i < startingDay; i++) {
      html += '<span class="calendar__day calendar__day--empty"></span>';
    }
    
    for (let day = 1; day <= lastDay.getDate(); day++) {
      const date = new Date(year, month, day);
      const dateStr = formatDate(date);
      let classes = ['calendar__day'];
      
      if (isPast(date)) {
        classes.push('calendar__day--disabled');
      } else if (isBooked(dateStr)) {
        classes.push('calendar__day--booked');
      } else {
        classes.push('calendar__day--available');
      }
      
      if (isToday(date)) {
        classes.push('calendar__day--today');
      }
      
      if (selectedStart && dateStr === formatDate(selectedStart)) {
        classes.push('calendar__day--selected');
      }
      if (selectedEnd && dateStr === formatDate(selectedEnd)) {
        classes.push('calendar__day--selected');
      }
      if (selectedStart && selectedEnd) {
        const d = new Date(dateStr);
        if (d > selectedStart && d < selectedEnd) {
          classes.push('calendar__day--in-range');
        }
      }
      
      html += `<span class="${classes.join(' ')}" data-date="${dateStr}">${day}</span>`;
    }
    
    daysEl.innerHTML = html;
    
    daysEl.querySelectorAll('.calendar__day--available').forEach(dayEl => {
      dayEl.addEventListener('click', () => {
        const clickedDate = new Date(dayEl.dataset.date);
        
        if (!selectedStart || (selectedStart && selectedEnd)) {
          selectedStart = clickedDate;
          selectedEnd = null;
        } else if (clickedDate > selectedStart) {
          let hasBooked = false;
          let checkDate = new Date(selectedStart);
          while (checkDate <= clickedDate) {
            if (isBooked(formatDate(checkDate))) {
              hasBooked = true;
              break;
            }
            checkDate.setDate(checkDate.getDate() + 1);
          }
          
          if (hasBooked) {
            selectedStart = clickedDate;
            selectedEnd = null;
          } else {
            selectedEnd = clickedDate;
          }
        } else {
          selectedStart = clickedDate;
          selectedEnd = null;
        }
        
        renderBothCalendars();
      });
    });
  }

  function renderBothCalendars() {
    const year1 = currentDate.getFullYear();
    const month1 = currentDate.getMonth();
    
    let year2 = year1;
    let month2 = month1 + 1;
    if (month2 > 11) {
      month2 = 0;
      year2++;
    }
    
    renderCalendar(1, year1, month1);
    renderCalendar(2, year2, month2);
  }

  document.getElementById('prev-month')?.addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() - 1);
    const today = new Date();
    if (currentDate < new Date(today.getFullYear(), today.getMonth(), 1)) {
      currentDate = new Date(today.getFullYear(), today.getMonth(), 1);
    }
    renderBothCalendars();
  });

  document.getElementById('next-month')?.addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() + 1);
    renderBothCalendars();
  });

  renderBothCalendars();
</script>
