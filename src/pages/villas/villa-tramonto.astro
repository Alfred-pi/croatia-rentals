---
import Layout from '../../layouts/Layout.astro';

const villa = {
  name: 'Villa Tramonto',
  location: 'Korčula',
  price: 980,
  beds: 4,
  baths: 3,
  guests: 8,
  size: 280,
  images: [
    'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1200&q=85',
    'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&q=85',
    'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&q=85',
    'https://images.unsplash.com/photo-1575429198097-0414ec08e8cd?w=800&q=85',
    'https://images.unsplash.com/photo-1600566752355-35792bedcfea?w=800&q=85',
  ],
  gallery: [
    { src: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1200&q=85', caption: 'Villa exterior & pool' },
    { src: 'https://images.unsplash.com/photo-1575429198097-0414ec08e8cd?w=1200&q=85', caption: 'Infinity pool with sea view' },
    { src: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1200&q=85', caption: 'Open plan living area' },
    { src: 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1200&q=85', caption: 'Master bedroom' },
    { src: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1200&q=85', caption: 'Guest bedroom' },
    { src: 'https://images.unsplash.com/photo-1600566752355-35792bedcfea?w=1200&q=85', caption: 'Outdoor dining terrace' },
    { src: 'https://images.unsplash.com/photo-1600566752229-250ed79470f8?w=1200&q=85', caption: 'Luxury bathroom' },
    { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=85', caption: 'Gourmet kitchen' },
    { src: 'https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=1200&q=85', caption: 'Sea view from terrace' },
    { src: 'https://images.unsplash.com/photo-1580137189272-c9379f8864fd?w=1200&q=85', caption: 'Korčula Old Town nearby' },
  ],
  features: ['Sea View', 'Infinity Pool', 'Historic Stone', 'Wine Cellar', 'Garden', 'BBQ Area', 'Home Cinema'],
  amenities: ['Heated infinity pool', 'Air conditioning', 'Fully equipped kitchen', 'High-speed WiFi', 'Smart home system', 'Private parking', 'Outdoor dining area', 'BBQ & pizza oven', 'Laundry facilities', 'Daily housekeeping', 'Concierge service', 'Private chef available'],
};

const related = [
  { name: 'Casa Blu', location: 'Hvar', price: 1200, image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=85', slug: 'casa-blu' },
  { name: 'Villa Oliva', location: 'Split', price: 750, image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=85', slug: 'villa-oliva' },
];

const airbnbLink = 'https://airbnb.com/rooms/456789';
---

<Layout title={`${villa.name} — ADRIATIC`}>
  <!-- Hero Gallery -->
  <section class="gallery">
    <div class="gallery__main">
      <img src={villa.images[0]} alt={villa.name} />
      <div class="gallery__badges">
        <span class="gallery__badge">★ 4.98</span>
        <span class="gallery__badge gallery__badge--host">Superhost</span>
      </div>
      <button class="gallery__view-all" id="open-lightbox">View all {villa.gallery.length} photos</button>
    </div>
    <div class="gallery__grid">
      {villa.images.slice(1, 5).map((img, i) => (
        <div class="gallery__item" data-index={i + 1}>
          <img src={img} alt={`${villa.name} ${i + 2}`} loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox__close" id="close-lightbox">×</button>
    <button class="lightbox__nav lightbox__nav--prev" id="lightbox-prev">←</button>
    <button class="lightbox__nav lightbox__nav--next" id="lightbox-next">→</button>
    <div class="lightbox__content">
      <img id="lightbox-img" src="" alt="" />
      <p class="lightbox__caption" id="lightbox-caption"></p>
      <span class="lightbox__counter" id="lightbox-counter"></span>
    </div>
  </div>

  <!-- Availability Calendar -->
  <section class="availability reveal">
    <div class="availability__header">
      <span class="intro__number">—</span>
      <div>
        <span class="tag">Availability</span>
        <h3>Check Available Dates</h3>
      </div>
      <div class="availability__legend">
        <span class="legend-item"><span class="dot dot--available"></span> Available</span>
        <span class="legend-item"><span class="dot dot--booked"></span> Booked</span>
        <span class="legend-item"><span class="dot dot--selected"></span> Selected</span>
      </div>
    </div>
    <div class="calendar-wrapper">
      <div class="calendar" id="calendar-1">
        <div class="calendar__header">
          <button class="calendar__nav" id="prev-month">←</button>
          <span class="calendar__month" id="month-1"></span>
          <button class="calendar__nav" id="next-month">→</button>
        </div>
        <div class="calendar__weekdays">
          <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
        <div class="calendar__days" id="days-1"></div>
      </div>
      <div class="calendar" id="calendar-2">
        <div class="calendar__header">
          <span class="calendar__month" id="month-2"></span>
        </div>
        <div class="calendar__weekdays">
          <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
        <div class="calendar__days" id="days-2"></div>
      </div>
    </div>
    <div class="availability__cta">
      <p>Select your dates above or contact us for custom availability</p>
      <a href={airbnbLink} target="_blank" class="availability__airbnb">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.42 0 5.82 1.96 4.63 4.38c-.6 1.21-.93 2.6-.93 4.1 0 3.04 1.67 5.8 3.17 7.94.49.7.98 1.35 1.43 1.96.5.68.95 1.3 1.31 1.87.37.58.64 1.1.79 1.52.16.46.3.98.41 1.52.12.54.21 1.09.27 1.63.06.54.09 1.07.09 1.58 0 .4-.02.78-.07 1.13-.05.36-.12.69-.22.98-.1.3-.22.56-.37.78s-.32.4-.52.52c-.2.13-.43.2-.67.2-.24 0-.47-.07-.67-.2-.2-.12-.37-.3-.52-.52s-.27-.48-.37-.78c-.1-.29-.17-.62-.22-.98-.05-.35-.07-.73-.07-1.13 0-.51.03-1.04.09-1.58.06-.54.15-1.09.27-1.63.11-.54.25-1.06.41-1.52.15-.42.42-.94.79-1.52.36-.57.81-1.19 1.31-1.87.45-.61.94-1.26 1.43-1.96 1.5-2.14 3.17-4.9 3.17-7.94 0-1.5-.33-2.89-.93-4.1C18.18 1.96 15.58 0 12 0z"/></svg>
        View live availability on Airbnb
      </a>
    </div>
  </section>

  <!-- Header -->
  <section class="header reveal">
    <div class="header__content">
      <span class="tag">{villa.location}, Croatia</span>
      <h1>{villa.name}</h1>
      <div class="line"></div>
      <div class="header__specs">
        <span>{villa.beds} bedrooms</span>
        <span class="dot"></span>
        <span>{villa.baths} bathrooms</span>
        <span class="dot"></span>
        <span>{villa.guests} guests</span>
        <span class="dot"></span>
        <span>{villa.size}m²</span>
      </div>
    </div>
    <div class="header__booking">
      <div class="booking-card">
        <div class="booking-card__price">
          <span class="price">€{villa.price}</span>
          <span class="unit">/ night</span>
        </div>
        <div class="booking-card__dates">
          <div class="booking-card__field">
            <label>Check-in</label>
            <input type="date" />
          </div>
          <div class="booking-card__field">
            <label>Check-out</label>
            <input type="date" />
          </div>
        </div>
        <div class="booking-card__field">
          <label>Guests</label>
          <select>
            <option>2 guests</option>
            <option>4 guests</option>
            <option>6 guests</option>
            <option>8 guests</option>
          </select>
        </div>
        <a href="/croatia-rentals/contact/" class="btn btn--fill">Request Booking</a>
        <a href={airbnbLink} target="_blank" class="btn btn--airbnb">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.42 0 5.82 1.96 4.63 4.38c-.6 1.21-.93 2.6-.93 4.1 0 3.04 1.67 5.8 3.17 7.94.49.7.98 1.35 1.43 1.96.5.68.95 1.3 1.31 1.87.37.58.64 1.1.79 1.52.16.46.3.98.41 1.52.12.54.21 1.09.27 1.63.06.54.09 1.07.09 1.58 0 .4-.02.78-.07 1.13-.05.36-.12.69-.22.98-.1.3-.22.56-.37.78s-.32.4-.52.52c-.2.13-.43.2-.67.2-.24 0-.47-.07-.67-.2-.2-.12-.37-.3-.52-.52s-.27-.48-.37-.78c-.1-.29-.17-.62-.22-.98-.05-.35-.07-.73-.07-1.13 0-.51.03-1.04.09-1.58.06-.54.15-1.09.27-1.63.11-.54.25-1.06.41-1.52.15-.42.42-.94.79-1.52.36-.57.81-1.19 1.31-1.87.45-.61.94-1.26 1.43-1.96 1.5-2.14 3.17-4.9 3.17-7.94 0-1.5-.33-2.89-.93-4.1C18.18 1.96 15.58 0 12 0z"/></svg>
          Book on Airbnb
        </a>
        <p class="booking-card__note">Book directly for best rates, or via Airbnb</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features reveal">
    {villa.features.map(feature => (
      <span class="feature">{feature}</span>
    ))}
  </section>

  <!-- Photo Grid Section -->
  <section class="photo-grid">
    <div class="photo-grid__header reveal">
      <span class="intro__number">01</span>
      <div>
        <span class="tag">Gallery</span>
        <h3>Property Photos</h3>
      </div>
    </div>
    <div class="photo-grid__images">
      {villa.gallery.slice(0, 6).map((photo, i) => (
        <div class={`photo-grid__item ${i === 0 ? 'photo-grid__item--large' : ''}`} data-index={i}>
          <img src={photo.src} alt={photo.caption} loading="lazy" />
          <span class="photo-grid__caption">{photo.caption}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Description -->
  <section class="description">
    <div class="description__content reveal">
      <span class="intro__number">02</span>
      <span class="tag">The Property</span>
      <h2>A sunset paradise<br/>above the <em>Adriatic</em></h2>
      <div class="line"></div>
      <p>Villa Tramonto is a stunning 19th-century stone house that has been meticulously restored to offer the perfect blend of historic charm and contemporary luxury. Perched on a hillside overlooking the old town of Korčula, this exceptional property offers breathtaking panoramic views of the Adriatic Sea and the iconic city walls.</p>
      <p>The villa features four beautifully appointed bedrooms, each with its own ensuite bathroom and spectacular views. The open-plan living area flows seamlessly onto a large terrace where you can enjoy al fresco dining while watching the sunset paint the sky in shades of gold and crimson.</p>
      <p>The heated infinity pool appears to merge with the sea beyond, creating an unforgettable visual experience. Surrounded by Mediterranean gardens of lavender, olive trees, and bougainvillea, Villa Tramonto is truly a sanctuary of peace and beauty.</p>
    </div>
    <div class="description__image reveal">
      <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=800&q=85" alt="Sea view" />
    </div>
  </section>

  <!-- Room Details -->
  <section class="rooms reveal">
    <div class="rooms__header">
      <span class="intro__number">03</span>
      <div>
        <span class="tag">Spaces</span>
        <h3>Room by Room</h3>
      </div>
    </div>
    <div class="rooms__grid">
      <div class="room">
        <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=600&q=85" alt="Master bedroom" />
        <h4>Master Suite</h4>
        <p>King bed, ensuite bathroom, private balcony with sea view, walk-in closet</p>
      </div>
      <div class="room">
        <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?w=600&q=85" alt="Guest bedroom" />
        <h4>Guest Bedrooms (3)</h4>
        <p>Queen beds, ensuite bathrooms, garden or sea views, luxury linens</p>
      </div>
      <div class="room">
        <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=600&q=85" alt="Living room" />
        <h4>Living & Dining</h4>
        <p>Open plan design, floor-to-ceiling windows, fireplace, home cinema system</p>
      </div>
      <div class="room">
        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=85" alt="Kitchen" />
        <h4>Gourmet Kitchen</h4>
        <p>Professional appliances, wine fridge, espresso machine, outdoor kitchen</p>
      </div>
    </div>
  </section>

  <!-- Amenities -->
  <section class="amenities reveal">
    <div class="amenities__header">
      <span class="intro__number">04</span>
      <div>
        <span class="tag">What's Included</span>
        <h3>Amenities</h3>
      </div>
    </div>
    <div class="amenities__grid">
      {villa.amenities.map(amenity => (
        <div class="amenity">
          <span class="amenity__check">✓</span>
          <span>{amenity}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Location -->
  <section class="location reveal">
    <div class="location__content">
      <span class="intro__number">05</span>
      <span class="tag">Location</span>
      <h3>{villa.location}, Croatia</h3>
      <div class="line"></div>
      <p>Experience the magic of Korčula, the "Pearl of the Adriatic". Walk the ancient city walls, explore the marble streets of Old Town, or take a boat to the nearby Elaphiti Islands.</p>
      <div class="location__distances">
        <div class="distance">
          <span class="distance__value">5 min</span>
          <span class="distance__label">to Old Town</span>
        </div>
        <div class="distance">
          <span class="distance__value">15 min</span>
          <span class="distance__label">to Airport</span>
        </div>
        <div class="distance">
          <span class="distance__value">2 min</span>
          <span class="distance__label">to Beach</span>
        </div>
        <div class="distance">
          <span class="distance__value">Walking</span>
          <span class="distance__label">to Restaurants</span>
        </div>
      </div>
    </div>
    <div class="location__image">
      <img src="https://images.unsplash.com/photo-1580137189272-c9379f8864fd?w=800&q=85" alt="Korčula" />
    </div>
  </section>

  <!-- Related -->
  <section class="related">
    <div class="related__header reveal">
      <span class="intro__number">06</span>
      <div>
        <span class="tag">More Properties</span>
        <h3>You may also like</h3>
      </div>
      <a href="/croatia-rentals/villas/" class="link">View All →</a>
    </div>
    <div class="related__grid">
      {related.map((v, i) => (
        <a href={`/croatia-rentals/villas/${v.slug}/`} class="related-card reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="related-card__image">
            <img src={v.image} alt={v.name} loading="lazy" />
          </div>
          <div class="related-card__info">
            <span class="tag">{v.location}</span>
            <h4>{v.name}</h4>
            <span class="related-card__price">From €{v.price}/night</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* Availability Calendar */
  .availability {
    padding: 60px 10%;
    background: var(--light);
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .availability__header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 40px;
  }
  
  .availability__header h3 {
    font-size: 28px;
    margin-top: 8px;
  }
  
  .availability__legend {
    margin-left: auto;
    display: flex;
    gap: 24px;
  }
  
  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--gray);
  }
  
  .legend-item .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  
  .dot--available {
    background: #22c55e;
  }
  
  .dot--booked {
    background: #ef4444;
  }
  
  .dot--selected {
    background: var(--gold);
  }
  
  .calendar-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 40px;
  }
  
  .calendar {
    background: var(--white);
    padding: 32px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }
  
  .calendar__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }
  
  .calendar__month {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
  }
  
  .calendar__nav {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(0,0,0,0.1);
    background: transparent;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.3s;
  }
  
  .calendar__nav:hover {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }
  
  .calendar__weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: 8px;
  }
  
  .calendar__weekdays span {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
    padding: 8px 0;
  }
  
  .calendar__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  
  .calendar__day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }
  
  .calendar__day:hover:not(.calendar__day--disabled):not(.calendar__day--booked) {
    background: var(--light);
  }
  
  .calendar__day--empty {
    cursor: default;
  }
  
  .calendar__day--disabled {
    color: #ccc;
    cursor: not-allowed;
  }
  
  .calendar__day--booked {
    background: #fef2f2;
    color: #ef4444;
    cursor: not-allowed;
  }
  
  .calendar__day--booked::after {
    content: '';
    position: absolute;
    width: 60%;
    height: 1px;
    background: #ef4444;
    transform: rotate(-45deg);
  }
  
  .calendar__day--available {
    color: #22c55e;
  }
  
  .calendar__day--selected {
    background: var(--gold);
    color: var(--white);
  }
  
  .calendar__day--in-range {
    background: rgba(184, 134, 11, 0.15);
  }
  
  .calendar__day--today {
    font-weight: 600;
    border: 1px solid var(--black);
  }
  
  .availability__cta {
    text-align: center;
  }
  
  .availability__cta p {
    font-size: 14px;
    color: var(--gray);
    margin-bottom: 16px;
  }
  
  .availability__airbnb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #FF5A5F;
    transition: opacity 0.3s;
  }
  
  .availability__airbnb:hover {
    opacity: 0.7;
  }

  /* Gallery */
  .gallery {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 8px;
    padding-top: 80px;
  }
  
  .gallery__main {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  
  .gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .gallery__badges {
    position: absolute;
    top: 24px;
    left: 24px;
    display: flex;
    gap: 12px;
  }
  
  .gallery__badge {
    background: var(--white);
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 500;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
  }
  
  .gallery__badge--host {
    background: var(--gold);
    color: var(--white);
  }
  
  .gallery__view-all {
    position: absolute;
    bottom: 24px;
    right: 24px;
    background: var(--white);
    padding: 12px 24px;
    font-size: 13px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: all 0.3s;
  }
  
  .gallery__view-all:hover {
    background: var(--black);
    color: var(--white);
  }
  
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  
  .gallery__item {
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
  }
  
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  
  .gallery__item:hover img {
    transform: scale(1.05);
  }
  
  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }
  
  .lightbox.active {
    display: flex;
    opacity: 1;
  }
  
  .lightbox__close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255,255,255,0.3);
    background: transparent;
    color: var(--white);
    font-size: 28px;
    cursor: pointer;
    transition: all 0.3s;
  }
  
  .lightbox__close:hover {
    background: var(--white);
    color: var(--black);
  }
  
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    border: 1px solid rgba(255,255,255,0.3);
