  }
  
  .related-card__info h4 {
    font-size: 22px;
    margin: 8px 0;
  }
  
  .related-card__price {
    font-size: 14px;
    color: var(--gray);
  }
  
  .link {
    font-size: 13px;
    color: var(--black);
    display: inline-flex;
