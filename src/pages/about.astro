---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — ADRIATIC">
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="https://images.unsplash.com/photo-1555990538-1e15d5b97d8d?w=1600&q=90&auto=format" alt="Croatian coast" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="page-hero__content">
      <span>About Us</span>
      <h1>Our Story</h1>
      <p>Curating exceptional Croatian experiences since 2018</p>
    </div>
  </section>

  <section class="story">
    <div class="story__content">
      <p class="lead">ADRIATIC was founded with a simple belief: that Croatia's extraordinary coastline deserves an equally exceptional approach to hospitality.</p>
      <p>We curate a small collection of remarkable private villas, each selected for architectural distinction, prime location, and uncompromising quality. Our team handles every detail—from private chefs to yacht charters—so your only concern is where to watch the sunset.</p>
      <p>Based in Dubrovnik, we bring deep local knowledge and personal relationships to create experiences that reveal the authentic character of the Adriatic.</p>
    </div>
    <div class="story__image">
      <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=800&q=85&auto=format" alt="Croatian coast" />
    </div>
  </section>

  <section class="values">
    <div class="section-header section-header--center">
      <span class="section-tag">Our Values</span>
      <h2>The Adriatic Approach</h2>
    </div>
    <div class="values__grid">
      <div class="value">
        <span class="value__number">01</span>
        <h3>Curated Excellence</h3>
        <p>We personally visit and vet every property. Only the exceptional make our collection. No compromises.</p>
      </div>
      <div class="value">
        <span class="value__number">02</span>
        <h3>Local Expertise</h3>
        <p>Our Dubrovnik-based team knows every hidden beach, restaurant, and experience worth having.</p>
      </div>
      <div class="value">
        <span class="value__number">03</span>
        <h3>Personal Service</h3>
        <p>One dedicated concierge for your entire stay. Available 24/7. Your wish is our command.</p>
      </div>
    </div>
  </section>

  <section class="team">
    <div class="section-header section-header--center">
      <span class="section-tag">The Team</span>
      <h2>Meet Our Founders</h2>
    </div>
    <div class="team__grid">
      <div class="team-member">
        <div class="team-member__image">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=85&auto=format" alt="Team member" />
        </div>
        <h4>Marco Petrović</h4>
        <span>Co-Founder</span>
      </div>
      <div class="team-member">
        <div class="team-member__image">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&q=85&auto=format" alt="Team member" />
        </div>
        <h4>Ana Kovačević</h4>
        <span>Co-Founder</span>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Ready to experience<br/>the Adriatic?</h2>
    <p>Let us help you discover Croatia's most extraordinary villas.</p>
    <a href="/croatia-rentals/contact/" class="btn btn--primary">Get in Touch</a>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--white);
  }
  
  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  
  .page-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(12,74,110,0.7), rgba(15,20,25,0.8));
  }
  
  .page-hero__content span {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 16px;
    padding: 8px 16px;
    border: 1px solid var(--coral);
    border-radius: 20px;
  }
  
  .page-hero__content h1 {
    font-size: clamp(36px, 6vw, 56px);
    margin-bottom: 16px;
  }
  
  .page-hero__content p {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
  }
  
  .section-tag {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 16px;
  }
  
  .section-header--center {
    text-align: center;
    margin-bottom: 60px;
  }
  
  .section-header--center h2 {
    font-size: clamp(28px, 4vw, 40px);
    color: var(--black);
  }
  
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 5%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .story__content .lead {
    font-size: 22px;
    line-height: 1.6;
    color: var(--black);
    margin-bottom: 24px;
  }
  
  .story__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    margin-bottom: 20px;
  }
  
  .story__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 12px;
  }
  
  .story__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .values {
    padding: 100px 5%;
    background: var(--light);
  }
  
  .values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .value {
    text-align: center;
    padding: 40px;
    background: var(--white);
    border-radius: 12px;
  }
  
  .value__number {
    display: inline-block;
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--coral);
    padding: 8px 16px;
    border: 1px solid var(--coral);
    border-radius: 20px;
    margin-bottom: 24px;
  }
  
  .value h3 {
    font-size: 22px;
    margin-bottom: 16px;
    color: var(--black);
  }
  
  .value p {
    font-size: 15px;
    color: var(--gray);
    line-height: 1.8;
  }
  
  .team {
    padding: 100px 5%;
  }
  
  .team__grid {
    display: flex;
    justify-content: center;
    gap: 60px;
  }
  
  .team-member {
    text-align: center;
  }
  
  .team-member__image {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 24px;
  }
  
  .team-member__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .team-member h4 {
    font-size: 20px;
    margin-bottom: 4px;
    color: var(--black);
  }
  
  .team-member span {
    font-size: 14px;
    color: var(--coral);
  }
  
  .cta {
    background: var(--blue);
    padding: 100px 5%;
    text-align: center;
    color: var(--white);
  }
  
  .cta h2 {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 16px;
    line-height: 1.3;
  }
  
  .cta p {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 32px;
  }
  
  @media (max-width: 900px) {
    .story {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .values__grid {
      grid-template-columns: 1fr;
    }
    
    .team__grid {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
