---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="About — ADRIATIC">
  <section class="page-header">
    <span>About</span>
    <h1>Our Story</h1>
  </section>

  <section class="story">
    <div class="story__image">
      <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=800&q=85&auto=format" alt="Croatian coast" />
    </div>
    <div class="story__content">
      <p class="lead">ADRIATIC was founded with a simple belief: that Croatia's extraordinary coastline deserves an equally exceptional approach to hospitality.</p>
      <p>We curate a small collection of remarkable private villas, each selected for architectural distinction, prime location, and uncompromising quality. Our team handles every detail—from private chefs to yacht charters—so your only concern is where to watch the sunset.</p>
      <p>Based in Dubrovnik, we bring deep local knowledge and personal relationships to create experiences that reveal the authentic character of the Adriatic.</p>
    </div>
  </section>

  <section class="values">
    <div class="value">
      <span>01</span>
      <h3>Curated Excellence</h3>
      <p>We personally visit and vet every property. Only the exceptional make our collection.</p>
    </div>
    <div class="value">
      <span>02</span>
      <h3>Local Expertise</h3>
      <p>Our Dubrovnik-based team knows every hidden beach, restaurant, and experience worth having.</p>
    </div>
    <div class="value">
      <span>03</span>
      <h3>Personal Service</h3>
      <p>One dedicated concierge for your entire stay. Available 24/7.</p>
    </div>
  </section>

  <section class="cta">
    <h2>Ready to experience<br/>the Adriatic?</h2>
    <a href={`${base}contact/`} class="btn">Get in Touch</a>
  </section>
</Layout>

<style>
  .page-header {
    padding: 180px 5% 80px;
    text-align: center;
  }
  
  .page-header span {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 24px;
  }
  
  .page-header h1 {
    font-size: clamp(40px, 6vw, 64px);
  }
  
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 80px 10%;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }
  
  .story__image {
    aspect-ratio: 4/5;
    overflow: hidden;
  }
  
  .story__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .story__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    margin-bottom: 24px;
  }
  
  .story__content .lead {
    font-size: 20px;
    color: var(--black);
    line-height: 1.7;
  }
  
  .values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    padding: 100px 10%;
    background: var(--light);
  }
  
  .value span {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--gold);
    display: block;
    margin-bottom: 20px;
  }
  
  .value h3 {
    font-size: 22px;
    margin-bottom: 16px;
  }
  
  .value p {
    font-size: 15px;
    color: var(--gray);
    line-height: 1.8;
  }
  
  .cta {
    text-align: center;
    padding: 140px 5%;
  }
  
  .cta h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 40px;
    line-height: 1.3;
  }
  
  @media (max-width: 900px) {
    .story {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 60px 5%;
    }
    
    .values {
      grid-template-columns: 1fr;
      padding: 60px 5%;
    }
  }
</style>
