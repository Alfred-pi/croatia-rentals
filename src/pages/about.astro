---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — ADRIATIC">
  <section class="page-header">
    <span class="tag">About</span>
    <h1>Our Story</h1>
  </section>

  <section class="story">
    <div class="story__image">
      <img src="https://images.unsplash.com/photo-1555990538-1e15d5b97d8d?w=800&q=85" alt="Croatian coast" />
    </div>
    <div class="story__content">
      <p class="lead">ADRIATIC was founded with a simple belief: that Croatia's extraordinary coastline deserves an equally exceptional approach to hospitality.</p>
      <p>We curate a small collection of remarkable private villas, each selected for architectural distinction, prime location, and uncompromising quality.</p>
      <p>Our team handles every detail—from private chefs to yacht charters—so your only concern is where to watch the sunset.</p>
      <p>Based in Dubrovnik, we bring deep local knowledge and personal relationships to create experiences that reveal the authentic character of the Adriatic.</p>
    </div>
  </section>

  <section class="values">
    <div class="values__header">
      <span class="intro__number">01</span>
      <h2>Our Approach</h2>
    </div>
    <div class="values__grid">
      <div class="value">
        <h4>Curated Excellence</h4>
        <p>We personally visit and vet every property. Only the exceptional make our collection.</p>
      </div>
      <div class="value">
        <h4>Local Expertise</h4>
        <p>Our Dubrovnik-based team knows every hidden beach, restaurant, and experience worth having.</p>
      </div>
      <div class="value">
        <h4>Personal Service</h4>
        <p>One dedicated concierge for your entire stay. Available 24/7, for anything you need.</p>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Ready to experience<br/>the Adriatic?</h2>
    <a href="/croatia-rentals/contact/" class="btn">Get in Touch</a>
  </section>
</Layout>

<style>
  .page-header {
    padding: 180px 5% 80px;
    text-align: center;
  }
  
  .page-header h1 {
    font-size: clamp(40px, 6vw, 64px);
    margin-top: 16px;
  }
  
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 80px 10%;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }
  
  .story__image {
    aspect-ratio: 4/5;
    overflow: hidden;
  }
  
  .story__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .story__content .lead {
    font-size: 22px;
    line-height: 1.5;
    margin-bottom: 24px;
  }
  
  .story__content p {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.9;
    margin-bottom: 16px;
  }
  
  .values {
    padding: 100px 10%;
    background: var(--light);
  }
  
  .values__header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }
  
  .values__header h2 {
    font-size: 28px;
  }
  
  .intro__number {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--gold);
  }
  
  .values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }
  
  .value h4 {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 16px;
  }
  
  .value p {
    font-size: 15px;
    color: var(--gray);
    line-height: 1.8;
  }
  
  .cta {
    text-align: center;
    padding: 160px 5%;
  }
  
  .cta h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 40px;
    line-height: 1.2;
  }
  
  @media (max-width: 900px) {
    .story { grid-template-columns: 1fr; gap: 48px; padding: 60px 5%; }
    .values { padding: 60px 5%; }
    .values__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
